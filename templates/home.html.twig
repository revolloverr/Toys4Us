{% extends "layout.html.twig" %}

{% block title %}{{ trans('app.title') }}{% endblock %}

{% block content %}

<!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
<section class="hero-section text-center text-white rounded-4 p-5 mb-5"
         style="background: linear-gradient(135deg, var(--purple) 0%, var(--blue-purple) 100%);">
    <div class="py-4">
        <h1 class="display-4 fw-bold mb-3">{{ trans('hero.heading') }}</h1>
        <p class="lead mb-4 mx-auto" style="max-width: 600px;">{{ trans('hero.subheading') }}</p>
        <a href="{{ base_path }}/products" class="btn btn-light btn-lg text-purple fw-bold px-5 py-3">
            {{ trans('hero.cta') }} →
        </a>
    </div>
</section>


<!-- ─── Search ───────────────────────────────────────────────────────── -->
<section class="mb-5">
    <div class="d-flex gap-2 justify-content-center position-relative">
        <div class="position-relative" style="max-width: 500px; flex-grow:1;">
            <input type="text" id="home-search-input" class="form-control form-control-lg"
                   placeholder="{{ trans('home.search_placeholder') }}"
                   value="{{ search ?? '' }}"
                   autocomplete="off">
            <div id="home-search-results" class="position-absolute w-100 shadow-sm rounded"
                 style="z-index:1000; display:none; max-height:400px; overflow-y:auto; background:#fff; border:1px solid #ddd;"></div>
        </div>
        <a href="{{ base_path }}/products" class="btn btn-purple btn-lg px-4"><i class="bi bi-search me-1"></i>{{ trans('home.search_btn') }}</a>
    </div>
</section>

<!-- ─── CATEGORIES ───────────────────────────────────────────────────────── -->
<section class="mb-5">
    <h2 class="h4 fw-bold text-purple mb-4">{{ trans('home.categories_title') }}</h2>
    <div class="row g-4">
        <div class="col-6 col-md-3">
            <a href="{{ base_path }}/build" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center h-100 category-card">
                    <div class="card-body py-4">
                        <div class="fs-1 mb-2">
                            <img src="{{ base_path }}/assets/icons/buildAPlush.png" alt="Build Your Own" style="width:60px;height:60px;object-fit:contain;">
                        </div>
                        <h6 class="fw-bold text-purple mb-1">{{ trans('category.build_your_own') }}</h6>
                        <small class="text-muted">{{ trans('category.build_your_own_desc') }}</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="{{ base_path }}/products?category=board-games" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center h-100 category-card">
                    <div class="card-body py-4">
                        <div class="fs-1 mb-2">
                            <img src="{{ base_path }}/assets/icons/boardCategory.png" alt="Board Games" style="width:60px;height:60px;object-fit:contain;">
                        </div>
                        <h6 class="fw-bold text-purple mb-1">{{ trans('category.board_games') }}</h6>
                        <small class="text-muted">{{ trans('category.board_games_desc') }}</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="{{ base_path }}/products?category=outdoor" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center h-100 category-card">
                    <div class="card-body py-4">
                        <div class="fs-1 mb-2">
                            <img src="{{ base_path }}/assets/icons/outdoorCategory.png" alt="Outdoor" style="width:60px;height:60px;object-fit:contain;">
                        </div>
                        <h6 class="fw-bold text-purple mb-1">{{ trans('category.outdoor') }}</h6>
                        <small class="text-muted">{{ trans('category.outdoor_desc') }}</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="{{ base_path }}/products?category=educational" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center h-100 category-card">
                    <div class="card-body py-4">
                        <div class="fs-1 mb-2">
                            <img src="{{ base_path }}/assets/icons/educationalCategory.png" alt="Educational" style="width:60px;height:60px;object-fit:contain;">
                        </div>
                        <h6 class="fw-bold text-purple mb-1">{{ trans('category.educational') }}</h6>
                        <small class="text-muted">{{ trans('category.educational_desc') }}</small>
                    </div>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- ─── FEATURED PRODUCTS ───────────────────────────────────────────────── -->
<section>
    <h2 class="h4 fw-bold text-purple mb-4">{{ trans('home.featured_title') }}</h2>
    <div class="row g-4">
        {% for product in featured %}
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 shadow-sm border-0">
                    <img src="{{ product.image }}" class="card-img-top" alt="{{ product.name }}" style="height:180px;object-fit:contain;">
                    <div class="card-body d-flex flex-column">
                        <h6 class="fw-bold mb-1">{{ product.name }}</h6>
                        <p class="card-text text-muted small flex-grow-1">{{ product.description }}</p>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="fw-bold text-purple">${{ product.price|number_format(2) }}</span>
                            <a href="{{ base_path }}/products/{{ product.id }}" class="btn btn-purple btn-sm">
                                {{ trans('products.view') }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</section>

<script>
const basePath = "{{ base_path }}";
const homeSearchInput = document.getElementById('home-search-input');
const homeResultsBox = document.getElementById('home-search-results');
const homeNoResults = "{{ trans('products.no_results')|e('js') }}";
const homeViewText = "{{ trans('products.view')|e('js') }}";
let homeDebounce = null;

if (homeSearchInput) {
    homeSearchInput.addEventListener('input', function() {
        clearTimeout(homeDebounce);
        const q = this.value.trim();
        if (q.length < 2) {
            homeResultsBox.style.display = 'none';
            return;
        }
        homeDebounce = setTimeout(() => {
            fetch(basePath + '/products/search-json?q=' + encodeURIComponent(q))
                .then(res => res.json())
                .then(data => {
                    if (!data || data.length === 0) {
                        homeResultsBox.innerHTML = '<div class="p-3 text-muted small text-center">' + homeNoResults + '</div>';
                        homeResultsBox.style.display = 'block';
                        return;
                    }
                    let html = '';
                    data.slice(0, 6).forEach(p => {
                        html += '<a href="' + basePath + '/products/' + p.id + '" class="d-flex align-items-center gap-2 p-2 text-decoration-none border-bottom">';
                        if (p.image) html += '<img src="' + p.image + '" alt="" style="width:36px;height:36px;object-fit:cover;border-radius:4px;">';
                        html += '<div class="flex-grow-1"><div class="fw-bold small text-dark">' + escapeHtml(p.name) + '</div>';
                        html += '<div class="text-muted" style="font-size:0.75rem;">$' + p.price.toFixed(2) + '</div></div>';
                        html += '<span class="btn btn-purple btn-sm">' + homeViewText + '</span></a>';
                    });
                    homeResultsBox.innerHTML = html;
                    homeResultsBox.style.display = 'block';
                })
                .catch(() => { homeResultsBox.style.display = 'none'; });
        }, 300);
    });

    document.addEventListener('click', function(e) {
        if (!e.target.closest('#home-search-input') && !e.target.closest('#home-search-results')) {
            homeResultsBox.style.display = 'none';
        }
    });

    homeSearchInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            window.location.href = basePath + '/products?search=' + encodeURIComponent(this.value);
        }
    });

    function escapeHtml(str) {
        const div = document.createElement('div');
        div.textContent = str;
        return div.innerHTML;
    }
}
</script>

{% endblock %}
