{% extends "layout.html.twig" %}

{% block title %}{{ trans('app.title') }}{% endblock %}

{% block content %}

<!-- ─── HERO ─────────────────────────────────────────────────────────────── -->
<section class="hero-section text-center text-white rounded-4 p-5 mb-5"
         style="background: linear-gradient(135deg, var(--purple) 0%, var(--blue-purple) 100%);">
    <div class="py-4">
        <h1 class="display-4 fw-bold mb-3">{{ trans('hero.heading') }}</h1>
        <p class="lead mb-4 mx-auto" style="max-width: 600px;">{{ trans('hero.subheading') }}</p>
        <a href="{{ base_path }}/products" class="btn btn-light btn-lg text-purple fw-bold px-5 py-3">
            {{ trans('hero.cta') }} →
        </a>
    </div>
</section>

<!-- ─── CATEGORIES ───────────────────────────────────────────────────────── -->
<section class="mb-5">
    <h2 class="h4 fw-bold text-purple mb-4">{{ trans('home.categories_title') }}</h2>
    <div class="row g-4">
        <div class="col-6 col-md-3">
            <a href="{{ base_path }}/build" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center h-100 category-card">
                    <div class="card-body py-4">
                        <div class="fs-1 mb-2">🧩</div>
                        <h6 class="fw-bold text-purple mb-1">{{ trans('category.build_your_own') }}</h6>
                        <small class="text-muted">{{ trans('category.build_your_own_desc') }}</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="{{ base_path }}/products" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center h-100 category-card">
                    <div class="card-body py-4">
                        <div class="fs-1 mb-2">🎲</div>
                        <h6 class="fw-bold text-purple mb-1">{{ trans('category.board_games') }}</h6>
                        <small class="text-muted">{{ trans('category.board_games_desc') }}</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="{{ base_path }}/products" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center h-100 category-card">
                    <div class="card-body py-4">
                        <div class="fs-1 mb-2">⚽</div>
                        <h6 class="fw-bold text-purple mb-1">{{ trans('category.outdoor') }}</h6>
                        <small class="text-muted">{{ trans('category.outdoor_desc') }}</small>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a href="{{ base_path }}/products" class="text-decoration-none">
                <div class="card border-0 shadow-sm text-center h-100 category-card">
                    <div class="card-body py-4">
                        <div class="fs-1 mb-2">📚</div>
                        <h6 class="fw-bold text-purple mb-1">{{ trans('category.educational') }}</h6>
                        <small class="text-muted">{{ trans('category.educational_desc') }}</small>
                    </div>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- ─── FEATURED PRODUCTS ───────────────────────────────────────────────── -->
<section>
    <h2 class="h4 fw-bold text-purple mb-4">{{ trans('home.featured_title') }}</h2>
    <div class="row g-4">
        {% for product in featured %}
            <div class="col-12 col-sm-6 col-lg-3">
                <div class="card h-100 shadow-sm border-0">
                    <img src="{{ product.image_url }}" class="card-img-top" alt="{{ product.name }}" style="height:180px;object-fit:cover;">
                    <div class="card-body d-flex flex-column">
                        <h6 class="fw-bold mb-1">{{ product.name }}</h6>
                        <p class="card-text text-muted small flex-grow-1">{{ product.description }}</p>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <span class="fw-bold text-purple">${{ product.price|number_format(2) }}</span>
                            <a href="{{ base_path }}/products/{{ product.id }}" class="btn btn-purple btn-sm">
                                {{ trans('products.view') }}
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</section>

{% endblock %}