{% extends "layout.html.twig" %}

{% block title %}{{ trans('admin.title') }}{% endblock %}

{% block content %}

<div class="row justify-content-center">
    <div class="col-12 col-xl-11">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h4 text-purple fw-bold mb-0">{{ trans('admin.title') }}</h2>
        </div>

        {% if app.request.query.get('success') == '1' %}
            <div class="alert alert-success py-2 small mb-4">
                {{ trans('admin.success_message') }}
            </div>
        {% endif %}

        {# ── Tabs ─────────────────────────────────────────────────────────── #}
        <ul class="nav nav-tabs mb-4" id="adminTabs">
            <li class="nav-item">
                <a class="nav-link active"
                   href="#dashboard" data-bs-toggle="tab">
                    {{ trans('admin.tab_dashboard') }}
                </a>
            </li>

            <li class="nav-item">
                <a class="nav-link"
                   href="#management" data-bs-toggle="tab">
                    {{ trans('admin.tab_management') }}
                </a>
            </li>
        </ul>

        <div class="tab-content">

            {# ── Dashboard Tab ───────────────────────────────────────────── #}
            <div class="tab-pane fade show active" id="dashboard">

                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">

                        <h5 class="fw-bold mb-4">{{ trans('admin.dashboard_heading') }}</h5>

                        <div class="row g-3">

                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="border rounded text-center p-3 h-100">
                                    <div class="fs-2 mb-2"><i class="bi bi-box"></i></div>
                                    <div class="fw-bold fs-4 text-purple">
                                        {{ counts.products }}
                                    </div>
                                    <div class="text-muted small">
                                        {{ trans('admin.dashboard_products') }}
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="border rounded text-center p-3 h-100">
                                    <div class="fs-2 mb-2"><i class="bi bi-tags"></i></div>
                                    <div class="fw-bold fs-4 text-purple">
                                        {{ counts.categories }}
                                    </div>
                                    <div class="text-muted small">
                                        {{ trans('admin.dashboard_categories') }}
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="border rounded text-center p-3 h-100">
                                    <div class="fs-2 mb-2"><i class="bi bi-heart"></i></div>
                                    <div class="fw-bold fs-4 text-purple">
                                        {{ counts.bases }}
                                    </div>
                                    <div class="text-muted small">
                                        {{ trans('admin.dashboard_bases') }}
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="border rounded text-center p-3 h-100">
                                    <div class="fs-2 mb-2"><i class="bi bi-gem"></i></div>
                                    <div class="fw-bold fs-4 text-purple">
                                        {{ counts.accessories }}
                                    </div>
                                    <div class="text-muted small">
                                        {{ trans('admin.dashboard_accessories') }}
                                    </div>
                                </div>
                            </div>

                            

                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="border rounded text-center p-3 h-100">
                                    <div class="fs-2 mb-2"><i class="bi bi-cart"></i></div>
                                    <div class="fw-bold fs-4 text-purple">
                                        {{ counts.orders }}
                                    </div>
                                    <div class="text-muted small">
                                        {{ trans('admin.dashboard_orders') }}
                                    </div>
                                </div>
                            </div>

                            <div class="col-6 col-md-4 col-lg-2">
                                <div class="border rounded text-center p-3 h-100">
                                    <div class="fs-2 mb-2"><i class="bi bi-person"></i></div>
                                    <div class="fw-bold fs-4 text-purple">
                                        {{ counts.users }}
                                    </div>
                                    <div class="text-muted small">
                                        {{ trans('admin.dashboard_users') }}
                                    </div>
                                </div>
                            </div>

                        </div>

                    </div>
                </div>

            </div>

            {# ── Management Tab ──────────────────────────────────────────── #}
            <div class="tab-pane fade" id="management">

                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">

                        <h5 class="fw-bold mb-4">{{ trans('admin.management_heading') }}</h5>

                        <div class="row g-3">

                            <div class="col-12 col-md-6">
                                <a href="{{ base_path }}/admin/products"
                                   class="card border text-decoration-none h-100">

                                    <div class="card-body text-center py-4">
                                        <div class="fs-1 mb-2"><i class="bi bi-box"></i></div>

                                        <h5 class="fw-bold text-purple">
                                            {{ trans('admin.dashboard_products') }}
                                        </h5>

                                        <p class="text-muted small mb-0">
                                            {{ trans('admin.products_desc') }}
                                        </p>
                                    </div>

                                </a>
                            </div>

                            <div class="col-12 col-md-6">
                                <a href="{{ base_path }}/admin/categories"
                                   class="card border text-decoration-none h-100">

                                    <div class="card-body text-center py-4">
                                        <div class="fs-1 mb-2"><i class="bi bi-tags"></i></div>

                                        <h5 class="fw-bold text-purple">
                                            {{ trans('admin.dashboard_categories') }}
                                        </h5>

                                        <p class="text-muted small mb-0">
                                            {{ trans('admin.categories_desc') }}
                                        </p>
                                    </div>

                                </a>
                            </div>

                            <div class="col-12 col-md-6">
                                <a href="{{ base_path }}/admin/bases"
                                   class="card border text-decoration-none h-100">

                                    <div class="card-body text-center py-4">
                                        <div class="fs-1 mb-2"><i class="bi bi-heart"></i></div>

                                        <h5 class="fw-bold text-purple">
                                            {{ trans('admin.dashboard_bases') }}
                                        </h5>

                                        <p class="text-muted small mb-0">
                                            {{ trans('admin.bases_desc') }}
                                        </p>
                                    </div>

                                </a>
                            </div>

                            <div class="col-12 col-md-6">
                                <a href="{{ base_path }}/admin/accessories"
                                   class="card border text-decoration-none h-100">

                                    <div class="card-body text-center py-4">
                                        <div class="fs-1 mb-2"><i class="bi bi-gem"></i></div>

                                        <h5 class="fw-bold text-purple">
                                            {{ trans('admin.dashboard_accessories') }}
                                        </h5>

                                        <p class="text-muted small mb-0">
                                            {{ trans('admin.accessories_desc') }}
                                        </p>
                                    </div>

                                </a>
                            </div>

                            <div class="col-12 col-md-6">
                                <a href="{{ base_path }}/admin/users"
                                    class="card border text-decoration-none h-100">
                                    
                                    <div class="card-body text-center py-4">
                                        <div class="fs-1 mb-2"><i class="bi bi-person"></i></div>

                                        <h5 class="fw-bold text-purple">
                                            {{ trans('admin.dashboard_users') }}
                                        </h5>

                                        <p class="text-muted small mb-0">
                                            {{ trans('admin.users_desc') }}
                                        </p>
                                    </div>

                                </a>
                            </div>

                            <div class="col-12 col-md-6">
                                <a href="{{ base_path }}/admin/orders"
                                    class="card border text-decoration-none h-100">

                                    <div class="card-body text-center py-4">
                                        <div class="fs-1 mb-2"><i class="bi bi-receipt"></i></div>

                                        <h5 class="fw-bold text-purple">
                                            {{ trans('admin.dashboard_orders') }}
                                        </h5>

                                        <p class="text-muted small mb-0">
                                            {{ trans('admin.orders_desc') ?? 'Manage customer orders and statuses' }}
                                        </p>
                                    </div>

                                </a>
                            </div>

                        </div>

                    </div>
                </div>

            </div>

        </div>

    </div>
</div>

{% endblock %}