{% extends "layout.html.twig" %}

{% block title %}{{ trans('admin.orders_title') }}{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 text-purple fw-bold mb-0">{{ trans('admin.orders_heading') }}</h2>
    <a href="{{ base_path }}/admin" class="btn btn-outline-secondary btn-sm">{{ trans('admin.back_to_admin') }}</a>
</div>

{% if app.request.query.get('success') == '1' %}
    <div class="alert alert-success py-2 small mb-4">
        {{ trans('admin.success_message') }}
    </div>
{% endif %}

<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>{{ trans('admin.table_id') }}</th>
                        <th>{{ trans('admin.table_customer') }}</th>
                        <th>{{ trans('admin.table_created_at') }}</th>
                        <th>{{ trans('admin.table_status') }}</th>
                        <th>{{ trans('admin.table_total') }}</th>
                        <th>{{ trans('admin.table_items') }}</th>
                        <th>{{ trans('admin.table_actions') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% if orders is empty %}
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                {{ trans('admin.orders_empty') }}
                            </td>
                        </tr>
                    {% else %}
                        {% for order in orders %}
                            {% set orderItems = order.items ?? [] %}
                            {% set itemCount = orderItems|length %}
                            <tr>
                                <td>#{{ order.id }}</td>
                                <td>
                                    {% if order.user_name is defined and order.user_name %}
                                        {{ order.user_name|e }}
                                    {% else %}
                                        <span class="text-muted">{{ trans('admin.orders_unknown_user') }}</span>
                                    {% endif %}
                                    {% if order.user_email is defined and order.user_email %}
                                        <div class="text-muted small">{{ order.user_email|e }}</div>
                                    {% endif %}
                                </td>
                                <td>{{ order.created_at }}</td>
                                <td>
                                    <span class="badge
                                        {% if order.status == 'paid' %}bg-success
                                        {% elseif order.status == 'pending' %}bg-warning text-dark
                                        {% elseif order.status == 'shipped' %}bg-primary
                                        {% elseif order.status == 'cancelled' %}bg-danger
                                        {% else %}bg-secondary
                                        {% endif %}">
                                        {{ order.status|capitalize }}
                                    </span>
                                </td>
                                <td class="fw-bold text-purple">${{ order.total }}</td>
                                <td>
                                    <span class="text-muted">{{ itemCount }} </span>
                                </td>
                                <td>
                                    <form action="{{ base_path }}/admin/orders/update-status" method="POST" class="m-0 d-flex gap-2 align-items-center">
                                        <input type="hidden" name="order_id" value="{{ order.id }}">
                                        <select name="status" class="form-select form-select-sm w-auto" required>
                                            {% set s = order.status ?? '' %}
                                            {% for option in ['pending','paid','shipped','cancelled'] %}
                                                <option value="{{ option }}" {{ s == option ? 'selected' : '' }}>
                                                    {{ option|capitalize }}
                                                </option>
                                            {% endfor %}
                                        </select>
                                        <button type="submit" class="btn btn-purple btn-sm">{{ trans('admin.btn_save') }}</button>
                                    </form>
                                </td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}

