{% extends "layout.html.twig" %}

{% block title %}Accessories - Admin{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">Accessories</h2>
    <a href="{{ base_path }}/admin" class="btn btn-outline-secondary btn-sm">← Back to Admin</a>
</div>

<div class="row g-4">
    {# ── Add Form ── #}
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Add Accessory</h5>
                <form action="{{ base_path }}/admin/accessories/store" method="POST">
                    <div class="mb-2">
                        <label class="form-label small">Name</label>
                        <input type="text" name="name" class="form-control" placeholder="e.g. Bow, Glasses" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Category</label>
                        <select name="category" class="form-select" required>
                            <option value="">Select category...</option>
                            <option value="facewear">Face Wear</option>
                            <option value="bodywear">Body Wear</option>
                            <option value="shoes">Shoes</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Image Path</label>
                        <input type="text" name="image_path" class="form-control" placeholder="assets/accessories/bow.png" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Price ($)</label>
                        <input type="number" name="price" class="form-control" step="0.01" min="0" required>
                    </div>
                    <button type="submit" class="btn btn-purple w-100 mt-2">Add Accessory</button>
                </form>
            </div>
        </div>
    </div>

    {# ── Accessories List ── #}
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Preview</th>
                                <th>Name</th>
                                <th>Category</th>
                                <th>Price</th>
                                <th>Active</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for acc in accessories %}
                            <tr>
                                <form action="{{ base_path }}/admin/accessories/update" method="POST">
                                    <input type="hidden" name="id" value="{{ acc.id }}">
                                    <td>{{ acc.id }}</td>
                                    <td>
                                        {% if acc.image_path %}
                                        <img src="{{ base_path }}/{{ acc.image_path }}" alt="" style="width:36px;height:36px;object-fit:contain;">
                                        {% else %}
                                        <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td><input type="text" name="name" value="{{ acc.name }}" class="form-control form-control-sm" style="min-width:100px;"></td>
                                    <td>
                                        <select name="category" class="form-select form-select-sm" style="min-width:100px;">
                                            <option value="facewear" {{ acc.category == 'facewear' ? 'selected' : '' }}>Face Wear</option>
                                            <option value="bodywear" {{ acc.category == 'bodywear' ? 'selected' : '' }}>Body Wear</option>
                                            <option value="shoes" {{ acc.category == 'shoes' ? 'selected' : '' }}>Shoes</option>
                                        </select>
                                    </td>
                                    <td><input type="number" name="price" value="{{ acc.price }}" class="form-control form-control-sm" step="0.01" style="width:70px;"></td>
                                    <td>
                                        <div class="form-check">
                                            <input type="checkbox" name="is_active" class="form-check-input" value="1" {{ acc.is_active ? 'checked' : '' }}>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button type="submit" class="btn btn-purple btn-sm">Save</button>
                                </form>
                                <form action="{{ base_path }}/admin/accessories/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this accessory?')">
                                    <input type="hidden" name="id" value="{{ acc.id }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                                        </div>
                                    </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}