{% extends "layout.html.twig" %}

{% block title %}{{ trans('admin.accessories_title') }}{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">{{ trans('admin.accessories_heading') }}</h2>
    <a href="{{ base_path }}/admin" class="btn btn-outline-secondary btn-sm">{{ trans('admin.back_to_admin') }}</a>
</div>

<div class="row g-4">
    {# ── Add Form ── #}
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="fw-bold mb-3">{{ trans('admin.add_accessory') }}</h5>
                <form action="{{ base_path }}/admin/accessories/store" method="POST">
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_name') }}</label>
                        <input type="text" name="name" class="form-control" placeholder="e.g. Bow, Glasses" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_category') }}</label>
                        <select name="category" class="form-select" required>
                            <option value="">{{ trans('admin.form_category_select') }}</option>
                            <option value="facewear">{{ trans('admin.form_face_wear') }}</option>
                            <option value="bodywear">{{ trans('admin.form_body_wear') }}</option>
                            <option value="shoes">{{ trans('admin.form_shoes') }}</option>
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_image_path') }}</label>
                        <input type="text" name="image_path" class="form-control" placeholder="assets/accessories/bow.png" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_price') }}</label>
                        <input type="number" name="price" class="form-control" step="0.01" min="0" required>
                    </div>
                    <button type="submit" class="btn btn-purple w-100 mt-2">{{ trans('admin.btn_add') }}</button>
                </form>
            </div>
        </div>
    </div>

    {# ── Accessories List ── #}
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>{{ trans('admin.table_id') }}</th>
                                <th>{{ trans('admin.table_preview') }}</th>
                                <th>{{ trans('admin.table_image') }}</th>
                                <th>{{ trans('admin.table_name') }}</th>
                                <th>{{ trans('admin.table_category') }}</th>
                                <th>{{ trans('admin.table_price') }}</th>
                                <th>{{ trans('admin.table_active') }}</th>
                                <th>{{ trans('admin.table_actions') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for acc in accessories %}
                            <tr>
                                <form action="{{ base_path }}/admin/accessories/update" method="POST">
                                    <input type="hidden" name="id" value="{{ acc.id }}">
                                    <td>{{ acc.id }}</td>
                                    <td>
                                        {% if acc.image_path %}
                                        <img src="{{ base_path }}/{{ acc.image_path }}" alt="" style="width:36px;height:36px;object-fit:contain;">
                                        {% else %}
                                        <span class="text-muted">{{ trans('admin.no_image') }}</span>
                                        {% endif %}
                                    </td>
                                    <td><input type="text" name="image_path" value="{{ acc.image_path }}" class="form-control form-control-sm" style="min-width:120px;" placeholder="assets/accessories/xyz.png"></td>
                                    <td><input type="text" name="name" value="{{ acc.name }}" class="form-control form-control-sm" style="min-width:100px;"></td>
                                    <td>
                                        <select name="category" class="form-select form-select-sm" style="min-width:100px;">
                                            <option value="facewear" {{ acc.category == 'facewear' ? 'selected' : '' }}>{{ trans('admin.form_face_wear') }}</option>
                                            <option value="bodywear" {{ acc.category == 'bodywear' ? 'selected' : '' }}>{{ trans('admin.form_body_wear') }}</option>
                                            <option value="shoes" {{ acc.category == 'shoes' ? 'selected' : '' }}>{{ trans('admin.form_shoes') }}</option>
                                        </select>
                                    </td>
                                    <td><input type="number" name="price" value="{{ acc.price }}" class="form-control form-control-sm" step="0.01" style="width:70px;"></td>
                                    <td>
                                        <div class="form-check">
                                            <input type="checkbox" name="is_active" class="form-check-input" value="1" {{ acc.is_active ? 'checked' : '' }}>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button type="submit" class="btn btn-purple btn-sm">{{ trans('admin.btn_save') }}</button>
                                </form>
                                <form action="{{ base_path }}/admin/accessories/delete" method="POST" class="d-inline" onsubmit="return confirm('{{ trans('admin.confirm_delete_accessory') }}')">
                                    <input type="hidden" name="id" value="{{ acc.id }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">{{ trans('admin.btn_delete') }}</button>
                                </form>
                                        </div>
                                    </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}