{% extends "layout.html.twig" %}

{% block title %}{{ trans('admin.users_title') }}{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 text-purple fw-bold mb-0">{{ trans('admin.users_heading') }}</h2>
    <a href="{{ base_path }}/admin" class="btn btn-outline-secondary btn-sm">{{ trans('admin.back_to_admin') }}</a>
</div>

{# ── Search ───────────────────────────────────────────────────────────────── #}
<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="GET" action="{{ base_path }}/admin/users" class="d-flex gap-2">
            <input type="text" name="search" class="form-control"
                   placeholder="{{ trans('products.search_placeholder') }}"
                   value="{{ search ?? '' }}">
            <button type="submit" class="btn btn-purple">{{ trans('products.search_btn') }}</button>
            {% if search is defined and search %}
                <a href="{{ base_path }}/admin/users" class="btn btn-outline-secondary">{{ trans('products.filter_clear') }}</a>
            {% endif %}
        </form>
    </div>
</div>

{# ── Table ────────────────────────────────────────────────────────────────── #}
<div class="card shadow-sm border-0">
    <div class="card-body">
        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>{{ trans('admin.table_id') }}</th>
                        <th>{{ trans('admin.table_name') }}</th>
                        <th>{{ trans('admin.table_email') }}</th>
                        <th>{{ trans('admin.table_role') }}</th>
                        <th>{{ trans('admin.table_actions') }}</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        {% set isCurrentUser = session.user.id == user.id %}
                        <tr>
                            <form action="{{ base_path }}/admin/users/update" method="POST">
                                <input type="hidden" name="id" value="{{ user.id }}">
                                <td>{{ user.id }}</td>
                                <td>
                                    <input type="text" name="name" class="form-control form-control-sm"
                                           value="{{ user.name }}" required
                                           {{ isCurrentUser ? 'disabled' : '' }}>
                                </td>
                                <td>
                                    <input type="email" name="email" class="form-control form-control-sm"
                                           value="{{ user.email }}" required
                                           {{ isCurrentUser ? 'disabled' : '' }}>
                                </td>
                                <td>
                                    <select name="role" class="form-select form-select-sm"
                                            {{ isCurrentUser ? 'disabled' : '' }}>
                                        <option value="user" {{ user.role == 'user' ? 'selected' : '' }}>{{ trans('profile.tab_account') }}</option>
                                        <option value="admin" {{ user.role == 'admin' ? 'selected' : '' }}>{{ trans('admin.role') }}</option>
                                    </select>
                                </td>
                                <td>
                                    {% if isCurrentUser %}
                                        <span class="badge bg-secondary">{{ trans('profile.title') }}</span>
                                    {% else %}
                                        <div class="d-flex gap-2">
                                            <button type="submit" class="btn btn-purple btn-sm">{{ trans('admin.btn_save') }}</button>
                                        </div>
                                    {% endif %}
                                </td>
                            </form>

                            {# Delete form — separate from update form #}
                            {% if not isCurrentUser %}
                            <td style="display:none"></td>
                            <script>
                                document.currentScript.closest('tr').querySelector('.d-flex').insertAdjacentHTML('beforeend', `
                                    <form action="{{ base_path }}/admin/users/delete" method="POST" class="m-0"
                                          onsubmit="return confirm('{{ trans('admin.confirm_delete_user') }}')">
                                        <input type="hidden" name="id" value="{{ user.id }}">
                                        <button type="submit" class="btn btn-outline-danger btn-sm">{{ trans('admin.btn_delete') }}</button>
                                    </form>
                                `);
                            </script>
                            {% endif %}
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

{% endblock %}