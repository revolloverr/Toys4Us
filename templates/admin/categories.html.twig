{% extends "layout.html.twig" %}

{% block title %}Categories - Admin{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">Categories</h2>
    <a href="{{ base_path }}/admin" class="btn btn-outline-secondary btn-sm">← Back to Admin</a>
</div>

<div class="row g-4">
    {# ── Add Form ── #}
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Add Category</h5>
                <form action="{{ base_path }}/admin/categories/store" method="POST">
                    <div class="mb-2">
                        <label class="form-label small">Name</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Image URL</label>
                        <input type="text" name="image" class="form-control" placeholder="https://...">
                    </div>
                    <button type="submit" class="btn btn-purple w-100 mt-2">Add Category</button>
                </form>
            </div>
        </div>
    </div>

    {# ── Category List ── #}
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Name</th>
                                <th>Slug</th>
                                <th>Image</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for cat in categories %}
                            <tr>
                                <form action="{{ base_path }}/admin/categories/update" method="POST">
                                    <input type="hidden" name="id" value="{{ cat.id }}">
                                    <td>{{ cat.id }}</td>
                                    <td><input type="text" name="name" value="{{ cat.name }}" class="form-control form-control-sm" style="min-width:120px;"></td>
                                    <td><code>{{ cat.slug }}</code></td>
                                    <td><input type="text" name="image" value="{{ cat.image }}" class="form-control form-control-sm" style="min-width:120px;" placeholder="https://..."></td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button type="submit" class="btn btn-purple btn-sm">Save</button>
                                </form>
                                <form action="{{ base_path }}/admin/categories/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this category?')">
                                    <input type="hidden" name="id" value="{{ cat.id }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                                        </div>
                                    </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}