{% extends "layout.html.twig" %}

{% block title %}{{ trans('admin.bases_title') }}{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">{{ trans('admin.bases_heading') }}</h2>
    <a href="{{ base_path }}/admin" class="btn btn-outline-secondary btn-sm">{{ trans('admin.back_to_admin') }}</a>
</div>

<div class="row g-4">
    {# ── Add Form ── #}
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="fw-bold mb-3">{{ trans('admin.add_base') }}</h5>
                <form action="{{ base_path }}/admin/bases/store" method="POST">
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_name') }}</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_species') }}</label>
                        <input type="text" name="species" class="form-control" placeholder="e.g. bear, cat, dog" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_color') }}</label>
                        <input type="text" name="color" class="form-control" placeholder="e.g. purple, pink, blue" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_image_path') }}</label>
                        <input type="text" name="image_path" class="form-control" placeholder="assets/bases/bear_purple.png" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_base_price') }}</label>
                        <input type="number" name="base_price" class="form-control" step="0.01" min="0" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">{{ trans('admin.form_sort_order') }}</label>
                        <input type="number" name="sort_order" class="form-control" value="0">
                    </div>
                    <button type="submit" class="btn btn-purple w-100 mt-2">{{ trans('admin.btn_add') }}</button>
                </form>
            </div>
        </div>
    </div>

    {# ── Bases List with Preview ── #}
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>{{ trans('admin.table_id') }}</th>
                                <th>{{ trans('admin.table_preview') }}</th>
                                <th>{{ trans('admin.table_image') }}</th>
                                <th>{{ trans('admin.table_name') }}</th>
                                <th>{{ trans('admin.table_species') }}</th>
                                <th>{{ trans('admin.table_color') }}</th>
                                <th>{{ trans('admin.table_price') }}</th>
                                <th>{{ trans('admin.table_active') }}</th>
                                <th>{{ trans('admin.table_actions') }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for base in bases %}
                            <tr>
                                <form action="{{ base_path }}/admin/bases/update" method="POST">
                                    <input type="hidden" name="id" value="{{ base.id }}">
                                    <td>{{ base.id }}</td>
                                    <td>
                                        <img src="{{ base_path }}/{{ base.image_path }}" alt="" style="width:36px;height:36px;object-fit:contain;">
                                    </td>
                                    <td><input type="text" name="image_path" value="{{ base.image_path }}" class="form-control form-control-sm" style="min-width:120px;" placeholder="assets/bases/xyz.png"></td>
                                    <td><input type="text" name="name" value="{{ base.name }}" class="form-control form-control-sm" style="min-width:100px;"></td>
                                    <td><input type="text" name="species" value="{{ base.species }}" class="form-control form-control-sm" style="min-width:80px;"></td>
                                    <td><input type="text" name="color" value="{{ base.color }}" class="form-control form-control-sm" style="min-width:80px;"></td>
                                    <td><input type="number" name="base_price" value="{{ base.base_price }}" class="form-control form-control-sm" step="0.01" style="width:70px;"></td>
                                    <td>
                                        <div class="form-check">
                                            <input type="checkbox" name="is_active" class="form-check-input" value="1" {{ base.is_active ? 'checked' : '' }}>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button type="submit" class="btn btn-purple btn-sm">{{ trans('admin.btn_save') }}</button>
                                            </form>
                                            <form action="{{ base_path }}/admin/bases/delete" method="POST" class="d-inline" onsubmit="return confirm('{{ trans('admin.confirm_delete_base') }}')">
                                                <input type="hidden" name="id" value="{{ base.id }}">
                                                <button type="submit" class="btn btn-outline-danger btn-sm">{{ trans('admin.btn_delete') }}</button>
                                            </form>
                                        </div>
                                    </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}