{% extends "layout.html.twig" %}

{% block title %}Products - Admin{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">Products</h2>
    <a href="{{ base_path }}/admin" class="btn btn-outline-secondary btn-sm">← Back to Admin</a>
</div>

<div class="row g-4">
    {# ── Add Form ── #}
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Add Product</h5>
                <form action="{{ base_path }}/admin/products/store" method="POST">
                    <div class="mb-2">
                        <label class="form-label small">Name</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Description</label>
                        <textarea name="description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Price ($)</label>
                        <input type="number" name="price" class="form-control" step="0.01" min="0" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Stock</label>
                        <input type="number" name="stock" class="form-control" min="0" value="0">
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Category</label>
                        <select name="category_id" class="form-select">
                            <option value="">None</option>
                            {% for cat in categories %}
                            <option value="{{ cat.id }}">{{ cat.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Image URL</label>
                        <input type="text" name="image" class="form-control" placeholder="https://...">
                    </div>
                    <button type="submit" class="btn btn-purple w-100 mt-2">Add Product</button>
                </form>
            </div>
        </div>
    </div>

    {# ── Product List ── #}
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Preview</th>
                                <th>Name</th>
                                <th>Description</th>
                                <th>Image URL</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th>Category</th>
                                <th>Active</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for product in products %}
                            <tr>
                                <form action="{{ base_path }}/admin/products/update" method="POST">
                                    <input type="hidden" name="id" value="{{ product.id }}">
                                    <td>{{ product.id }}</td>
                                    <td>
                                        {% if product.image %}
                                        <img src="{{ product.image }}" alt="" style="width:40px;height:40px;object-fit:cover;border-radius:4px;">
                                        {% else %}
                                        <span class="text-muted">—</span>
                                        {% endif %}
                                    </td>
                                    <td><input type="text" name="name" value="{{ product.name }}" class="form-control form-control-sm" style="min-width:110px;"></td>
                                    <td><input type="text" name="description" value="{{ product.description }}" class="form-control form-control-sm" style="min-width:130px;"></td>
                                    <td><input type="text" name="image" value="{{ product.image }}" class="form-control form-control-sm" placeholder="https://..." style="min-width:130px;"></td>
                                    <td><input type="number" name="price" value="{{ product.price }}" class="form-control form-control-sm" step="0.01" style="width:75px;"></td>
                                    <td><input type="number" name="stock" value="{{ product.stock }}" class="form-control form-control-sm" min="0" style="width:65px;"></td>
                                    <td>
                                        <select name="category_id" class="form-select form-select-sm" style="min-width:110px;">
                                            <option value="">None</option>
                                            {% for cat in categories %}
                                            <option value="{{ cat.id }}" {{ product.category_id == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                                            {% endfor %}
                                        </select>
                                    </td>
                                    <td>
                                        <div class="form-check">
                                            <input type="checkbox" name="is_active" class="form-check-input" value="1" {{ product.is_active ? 'checked' : '' }}>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex gap-1">
                                            <button type="submit" class="btn btn-purple btn-sm">Save</button>
                                </form>
                                <form action="{{ base_path }}/admin/products/delete" method="POST" class="d-inline" onsubmit="return confirm('Delete this product?')">
                                    <input type="hidden" name="id" value="{{ product.id }}">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                                        </div>
                                    </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}
