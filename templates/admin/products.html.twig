{% extends "layout.html.twig" %}

{% block title %}Products - Admin{% endblock %}

{% block content %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">Products</h2>
    <a href="{{ base_path }}/admin" class="btn btn-outline-secondary btn-sm">← Back to Admin</a>
</div>

<div class="row g-4">
    {# ── Add / Edit Form ── #}
    <div class="col-12 col-lg-4">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="fw-bold mb-3" id="form-title">Add Product</h5>
                <form action="{{ base_path }}/admin/products/store" method="POST" id="product-form">
                    <div class="mb-2">
                        <label class="form-label small">Name</label>
                        <input type="text" name="name" class="form-control" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Description</label>
                        <textarea name="description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Price ($)</label>
                        <input type="number" name="price" class="form-control" step="0.01" min="0" required>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Stock</label>
                        <input type="number" name="stock" class="form-control" min="0" value="0">
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Category</label>
                        <select name="category_id" class="form-select">
                            <option value="">None</option>
                            {% for cat in categories %}
                            <option value="{{ cat.id }}">{{ cat.name }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="mb-2">
                        <label class="form-label small">Image URL</label>
                        <input type="text" name="image" class="form-control" placeholder="https://...">
                    </div>
                    <button type="submit" class="btn btn-purple w-100 mt-2">Add Product</button>
                </form>
            </div>
        </div>
    </div>

    {# ── Product List ── #}
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Image</th>
                                <th>Name</th>
                                <th>Price</th>
                                <th>Stock</th>
                                <th>Active</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for product in products %}
                            <tr>
                                <td>{{ product.id }}</td>
                                <td>
                                    <img src="{{ product.image }}" alt="" style="width:40px;height:40px;object-fit:cover;border-radius:4px;">
                                </td>
                                <td>{{ product.name }}</td>
                                <td>${{ product.price|number_format(2) }}</td>
                                <td>{{ product.stock }}</td>
                                <td>
                                    <span class="badge {{ product.is_active ? 'bg-success' : 'bg-secondary' }}">
                                        {{ product.is_active ? 'Yes' : 'No' }}
                                    </span>
                                </td>
                                <td>
                                    <div class="d-flex gap-1">
                                        <button class="btn btn-purple btn-sm" onclick="editProduct({{ product.id }}, '{{ product.name|e('js') }}', '{{ product.description|e('js') }}', {{ product.price }}, {{ product.stock }}, {{ product.category_id ?? 0 }}, '{{ product.image|e('js') }}', {{ product.is_active }})">
                                            Edit
                                        </button>
                                        <form action="{{ base_path }}/admin/products/delete" method="POST" class="m-0" onsubmit="return confirm('Delete this product?')">
                                            <input type="hidden" name="id" value="{{ product.id }}">
                                            <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}