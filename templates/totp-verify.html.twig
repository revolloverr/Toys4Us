{% extends "layout.html.twig" %}

{% block title %}{{ trans('auth.verify_title') }}{% endblock %}

{% block content %}

<div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-5">

        {% if error is defined %}
            <div class="alert alert-danger py-2 small mb-3">{{ error }}</div>
        {% endif %}

        {% if qr_code is defined %}
        {# ── Step 2: First-time TOTP setup ── #}
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body p-4 text-center">
                <h2 class="h4 text-purple fw-bold mb-3">{{ trans('auth.otp_setup_title') }}</h2>
                <p class="text-muted small mb-3">{{ trans('auth.otp_setup_instruction') }}</p>
                <div class="bg-purple-soft p-3 rounded d-inline-block mb-3">
                    <img src="{{ qr_code }}" alt="TOTP QR Code" class="img-fluid" style="max-width: 220px;">
                </div>
                <p class="text-muted small mb-2"><strong>{{ trans('auth.otp_secret_label') }}:</strong></p>
                <div class="d-flex justify-content-center mb-3">
                    <code class="bg-light p-2 rounded border" id="totpSecret" style="font-size: 0.85rem; letter-spacing: 2px;">{{ secret }}</code>
                    <button class="btn btn-sm btn-outline-secondary ms-2" onclick="copySecret()" title="{{ trans('auth.otp_copy_secret') }}">
                        <i class="bi bi-clipboard"></i>
                    </button>
                </div>
                <p class="text-muted small">{{ trans('auth.otp_setup_note') }}</p>
            </div>
        </div>
        {% endif %}

        {# ── Step 1 & 3: TOTP code entry ── #}
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <h2 class="h4 text-purple fw-bold mb-3">{{ trans('auth.verify_title') }}</h2>

                {% if qr_code is not defined %}
                <p class="text-muted small mb-3">{{ trans('auth.otp_enter_code') }}</p>
                {% endif %}

                <form action="{{ base_path }}/totp/verify" method="POST">
                    <div class="mb-3">
                        <label for="totp_code" class="form-label">{{ trans('auth.otp_label') }}</label>
                        <input type="text" class="form-control form-control-lg text-center" id="totp_code" name="totp_code"
                               inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code"
                               placeholder="{{ trans('auth.otp_ph') }}" required autofocus>
                    </div>
                    <button type="submit" class="btn btn-purple w-100">
                        {{ qr_code is defined ? trans('auth.setup_and_verify') : trans('auth.verify') }}
                    </button>
                </form>

                {% if qr_code is not defined and (has_totp is not defined or not has_totp) %}
                <div class="text-center mt-3">
                    <form action="{{ base_path }}/totp/skip" method="POST" class="d-inline">
                        <button type="submit" class="btn btn-link text-muted small">{{ trans('auth.otp_skip_setup') }}</button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>

    </div>
</div>

<script>
function copySecret() {
    const input = document.getElementById('totpSecret');
    const text = input.textContent;
    navigator.clipboard.writeText(text).then(() => {
        const btn = input.nextElementSibling;
        const icon = btn.querySelector('i');
        icon.classList.replace('bi-clipboard', 'bi-check-lg');
        setTimeout(() => icon.classList.replace('bi-check-lg', 'bi-clipboard'), 1500);
    });
}
</script>

{% endblock %}