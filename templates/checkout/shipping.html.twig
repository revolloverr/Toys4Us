{% extends "layout.html.twig" %}

{% block title %}{{ trans('checkout.shipping_title') ?? 'Shipping' }}{% endblock %}

{% block content %}
<div class="row mb-4">
    <div class="col">
        {% set _title = trans('checkout.shipping_heading')|default('Shipping details') %}
        {% set _sub = trans('checkout.shipping_sub')|default('Choose a saved address or enter a new one.') %}
        <h2 class="h4 text-purple fw-bold">{{ _title }}</h2>
        <p class="text-muted">{{ _sub }}</p>
    </div>
</div>

<form method="POST" action="{{ base_path }}/checkout/shipping" id="shipping-form" class="mb-4">
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body">
            {% set _saved = trans('checkout.saved_addresses')|default('Saved addresses') %}
            <h6 class="fw-bold text-purple mb-3">{{ _saved }}</h6>

                <div class="list-group mb-3">
                    {% if addresses is empty %}
                        {% set _noaddr = trans('checkout.no_addresses')|default('No saved addresses.') %}
                        <p class="text-muted small mb-3">{{ _noaddr }}</p>
                    {% else %}
                        {% for address in addresses %}
                            <label class="list-group-item list-group-item-action d-flex align-items-start gap-2">
                                <input class="form-check-input mt-1" type="radio" name="address_id" value="{{ address.id|e('html_attr') }}" {% if loop.first %}checked{% endif %}>
                                <div>
                                    <div class="fw-bold">{{ address.name|e }}</div>
                                    <div class="text-muted small">{{ address.address|e }}, {{ address.city|e }}, {{ address.province|e }} {{ address.postal_code|e }}</div>
                                </div>
                            </label>
                        {% endfor %}
                    {% endif %}
                    <label class="list-group-item list-group-item-action d-flex align-items-start gap-2">
                        <input class="form-check-input mt-1" type="radio" name="address_id" value="0" {% if addresses is empty %}checked{% endif %}>
                        <div>
                            {% set _usenew = trans('checkout.use_new_address')|default('Use a new address') %}
                            <div class="fw-bold">{{ _usenew }}</div>
                        </div>
                    </label>
                </div>

            <div id="new-address-fields" style="display:none;">
                <div class="row g-2 mb-2">
                    {% set _label_name = trans('checkout.name_label')|default('Full name') %}
                    {% set _label_address = trans('checkout.address_label')|default('Address') %}
                    {% set _label_city = trans('checkout.city_label')|default('City') %}
                    {% set _label_province = trans('checkout.province_label')|default('Province') %}
                    {% set _label_postal = trans('checkout.postal_label')|default('Postal code') %}
                    <div class="col-12">
                        <label class="form-label small">{{ _label_name }}</label>
                        <input type="text" name="name" class="form-control" maxlength="100" value="">
                    </div>
                    <div class="col-12">
                        <label class="form-label small">{{ _label_address }}</label>
                        <input type="text" name="address" class="form-control" maxlength="255" value="">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">{{ _label_city }}</label>
                        <input type="text" name="city" class="form-control" maxlength="100" value="">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">{{ _label_province }}</label>
                        <input type="text" name="province" class="form-control" maxlength="100" value="">
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small">{{ _label_postal }}</label>
                        <input type="text" name="postal_code" class="form-control" maxlength="20" value="">
                    </div>
                </div>
            </div>

                <div class="d-flex justify-content-between">
                <a href="{{ base_path }}/cart" class="btn btn-outline-secondary">{{ trans('cart.continue_shopping') }}</a>
                {% set _cont = trans('checkout.continue_to_payment')|default('Continue to payment') %}
                <button type="submit" class="btn btn-purple">{{ _cont }}</button>
            </div>
        </div>
    </div>
</form>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const radios = document.querySelectorAll('input[name="address_id"]');
    const newFields = document.getElementById('new-address-fields');

    function updateNewFields() {
        const selected = document.querySelector('input[name="address_id"]:checked');
        if (selected && selected.value === '0') {
            newFields.style.display = 'block';
        } else {
            newFields.style.display = 'none';
        }
    }

    radios.forEach(r => r.addEventListener('change', updateNewFields));
    updateNewFields();
});
</script>
{% endblock %}