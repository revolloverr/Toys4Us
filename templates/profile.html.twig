{% extends "layout.html.twig" %}

{% block title %}{{ trans('profile.title') }}{% endblock %}

{% block content %}

<div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-7">

        <h2 class="h4 text-purple fw-bold mb-4">{{ trans('profile.heading') }}</h2>

        {% if error is defined %}
            <div class="alert alert-danger py-2 small mb-3">{{ error }}</div>
        {% endif %}

        {% if app.request.query.get('updated') == '1' %}
            <div class="alert alert-success py-2 small mb-3">{{ trans('profile.updated_success') }}</div>
        {% endif %}

        {# ── Tabs ─────────────────────────────────────────────────────────── #}
        <ul class="nav nav-tabs mb-4" id="profileTabs">
            <li class="nav-item">
                <a class="nav-link {{ active_tab is not defined or active_tab == 'account' ? 'active' : '' }}"
                   href="#account" data-bs-toggle="tab">{{ trans('profile.tab_account') }}</a>
            </li>
            <li class="nav-item">
                <a class="nav-link {{ active_tab is defined and active_tab == 'security' ? 'active' : '' }}"
                   href="#security" data-bs-toggle="tab">{{ trans('profile.tab_security') }}</a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#orders" data-bs-toggle="tab">
                    {{ trans('profile.tab_orders') }}
                    {% if orders|length > 0 %}
                    <span class="badge bg-purple ms-1">{{ orders|length }}</span>
                    {% endif %}
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="#accessibility" data-bs-toggle="tab">{{ trans('profile.tab_accessibility') }}</a>
            </li>
        </ul>

        <div class="tab-content">

            {# ── Account Tab ──────────────────────────────────────────────── #}
            <div class="tab-pane fade {{ active_tab is not defined or active_tab == 'account' ? 'show active' : '' }}" id="account">
                <div class="card shadow-sm border-0">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">{{ trans('profile.account_details') }}</h5>
                        <form action="{{ base_path }}/profile/edit" method="POST">
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label">{{ trans('profile.first_name') }}</label>
                                    {% set nameParts = user.name|split(' ', 2) %}
                                    <input type="text" class="form-control" name="first_name"
                                           value="{{ nameParts[0] ?? '' }}" required>
                                </div>
                                <div class="col-6">
                                    <label class="form-label">{{ trans('profile.last_name') }}</label>
                                    <input type="text" class="form-control" name="last_name"
                                           value="{{ nameParts[1] ?? '' }}" required>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">{{ trans('profile.email') }}</label>
                                <input type="email" class="form-control" name="email"
                                       value="{{ user.email }}" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">{{ trans('profile.phone') }} <span class="text-muted small">{{ trans('profile.phone_optional') }}</span></label>
                                <input type="tel" class="form-control" name="phone"
                                       value="{{ user.phone ?? '' }}" placeholder="{{ trans('profile.phone_ph') }}">
                            </div>
                            <button type="submit" class="btn btn-purple">{{ trans('profile.save_changes') }}</button>
                        </form>
                    </div>
                </div>
            </div>

            {# ── Security Tab ─────────────────────────────────────────────── #}
            <div class="tab-pane fade {{ active_tab is defined and active_tab == 'security' ? 'show active' : '' }}" id="security">

                {# Change Password #}
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">{{ trans('profile.change_password') }}</h5>
                        <form action="{{ base_path }}/profile/change-password" method="POST">
                            <div class="mb-3">
                                <label class="form-label">{{ trans('profile.current_password') }}</label>
                                <div class="input-group">
                                    <input type="password" class="form-control" name="current_password"
                                           id="current_password" required>
                                    <button class="btn btn-outline-secondary" type="button"
                                            onclick="togglePassword('current_password', this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">{{ trans('profile.new_password') }}</label>
                                <div class="input-group">
                                    <input type="password" class="form-control" name="new_password"
                                           id="new_password" required>
                                    <button class="btn btn-outline-secondary" type="button"
                                            onclick="togglePassword('new_password', this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">{{ trans('profile.confirm_password') }}</label>
                                <div class="input-group">
                                    <input type="password" class="form-control" name="confirm_password"
                                           id="confirm_password" required>
                                    <button class="btn btn-outline-secondary" type="button"
                                            onclick="togglePassword('confirm_password', this)">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </div>
                            </div>
                            <button type="submit" class="btn btn-purple">{{ trans('profile.update_password') }}</button>
                        </form>
                    </div>
                </div>

                

                {# ── Two-Factor Authentication (TOTP) ── #}
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">{{ trans('profile.totp_heading') }}</h5>

                        {% if user.totp_secret is not empty and totp_pending_setup is not defined %}
                            {# TOTP is already enabled #}
                            <div class="d-flex align-items-center mb-3">
                                <span class="badge bg-success me-2">{{ trans('profile.totp_enabled') }}</span>
                                <span class="text-muted small">{{ trans('profile.totp_enabled_desc') }}</span>
                            </div>
                            <form action="{{ base_path }}/profile/totp/disable" method="POST" class="d-inline">
                                <button type="submit" class="btn btn-outline-danger btn-sm"
                                        onclick="return confirm('{{ trans('profile.totp_disable_confirm') }}')">
                                    {{ trans('profile.totp_disable') }}
                                </button>
                            </form>

                        {% elseif totp_pending_setup is defined %}
                            {# TOTP setup in progress — show QR and confirmation #}
                            <p class="text-muted small mb-3">{{ trans('auth.otp_setup_instruction') }}</p>
                            <div class="bg-purple-soft p-3 rounded d-inline-block mb-3 text-center w-100">
                                <img src="{{ totp_qr_code }}" alt="TOTP QR Code" class="img-fluid" style="max-width: 200px;">
                            </div>
                            <p class="text-muted small mb-2"><strong>{{ trans('auth.otp_secret_label') }}:</strong></p>
                            <div class="d-flex align-items-center mb-3">
                                <code class="bg-light p-2 rounded border flex-grow-1" id="totpSetupSecret" style="font-size: 0.85rem; letter-spacing: 2px;">{{ totp_secret }}</code>
                                <button class="btn btn-sm btn-outline-secondary ms-2" onclick="copySecret()" title="{{ trans('auth.otp_copy_secret') }}">
                                    <i class="bi bi-clipboard"></i>
                                </button>
                            </div>
                            <p class="text-muted small mb-3">{{ trans('auth.otp_setup_note') }} {{ trans('auth.otp_enter_code') }}</p>

                            <form action="{{ base_path }}/profile/totp/confirm" method="POST">
                                <div class="row g-2 align-items-end">
                                    <div class="col-7">
                                        <label for="totp_code" class="form-label small">{{ trans('auth.otp_label') }}</label>
                                        <input type="text" class="form-control" id="totp_code" name="totp_code"
                                               inputmode="numeric" pattern="[0-9]*" maxlength="6"
                                               placeholder="{{ trans('auth.otp_ph') }}" required>
                                    </div>
                                    <div class="col-5">
                                        <button type="submit" class="btn btn-purple w-100">{{ trans('auth.setup_and_verify') }}</button>
                                    </div>
                                </div>
                            </form>
                            <div class="mt-2">
                                <form action="{{ base_path }}/profile" method="GET" class="d-inline">
                                    <button type="submit" class="btn btn-link btn-sm text-muted">{{ trans('profile.totp_cancel') }}</button>
                                </form>
                            </div>

                        {% else %}
                            {# TOTP not enabled — prompt to set up #}
                            <p class="text-muted small mb-3">
                                {{ trans('profile.totp_enable_prompt') }}
                            </p>
                            <form action="{{ base_path }}/profile/totp/setup" method="POST">
                                <button type="submit" class="btn btn-purple btn-sm">{{ trans('profile.totp_enable_btn') }}</button>
                            </form>
                        {% endif %}
                    </div>
                </div>

                {# Delete Account #}
                <div class="card border-danger shadow-sm">
                    <div class="card-body p-4">
                        <h5 class="fw-bold text-danger mb-2">{{ trans('profile.delete_account') }}</h5>
                        <p class="text-muted small mb-3">
                            {{ trans('profile.delete_desc') }}
                        </p>
                        <button type="button" class="btn btn-outline-danger"
                                data-bs-toggle="modal" data-bs-target="#deleteModal">
                            {{ trans('profile.delete_btn') }} | Not working yet
                        </button>
                    </div>
                </div>

            </div>

            {# ── Orders Tab ── #}
            <div class="tab-pane fade" id="orders">
                {% if orders is empty %}
                    <div class="card shadow-sm border-0">
                        <div class="card-body p-4 text-center text-muted">
                            <i class="bi bi-bag-x fs-2 mb-2 d-block"></i>
                            {{ trans('profile.orders_empty') }}
                            <a href="{{ base_path }}/products" class="d-block mt-2">{{ trans('profile.orders_start_shopping') }}</a>
                        </div>
                    </div>
                {% else %}
                    {% for order in orders %}
                    <div class="card shadow-sm border-0 mb-3">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div>
                                    <p class="fw-bold mb-0">{{ trans('profile.order_ref', {'%id%': order.id}) }}</p>
                                    <p class="text-muted small mb-0">{{ order.created_at }}</p>
                                </div>
                                <div class="text-end">
                                    <span class="badge 
                                        {% if order.status == 'paid' %}bg-success
                                        {% elseif order.status == 'pending' %}bg-warning text-dark
                                        {% else %}bg-secondary{% endif %}">
                                        {{ trans('profile.order_status_label') }} {{ order.status|capitalize }}
                                    </span>
                                    <p class="fw-bold text-purple mb-0 mt-1">${{ order.total }}</p>
                                </div>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-sm mb-0">
                                    <thead>
                                        <tr>
                                            <th>{{ trans('profile.order_item') }}</th>
                                            <th>{{ trans('profile.order_qty') }}</th>
                                            <th class="text-end">{{ trans('profile.order_price') }}</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        {% for item in order.items %}
                                        <tr>
                                            <td>
                                                {% if item.product_name %}
                                                    {% if item.product_image %}
                                                    <img src="{{ item.product_image }}" style="width:28px;height:28px;object-fit:cover;border-radius:4px;" class="me-2">
                                                    {% endif %}
                                                    {{ item.product_name }}
                                                {% else %}
                                                    <i class="bi bi-stars me-1 text-purple"></i>{{ trans('profile.order_custom_plush') }}
                                                {% endif %}
                                            </td>
                                            <td>{{ item.quantity }}</td>
                                            <td class="text-end">${{ item.price }}</td>
                                        </tr>
                                        {% endfor %}
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                    {% endfor %}
                {% endif %}
            </div>

            {# ── Accessibility Tab ── #}
            <div class="tab-pane fade" id="accessibility">
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">{{ trans('profile.accessibility_heading') }}</h5>

                        {# Theme #}
                        <div class="mb-4">
                            <h6 class="fw-bold text-purple mb-2">{{ trans('profile.a11y_theme') }}</h6>
                            <div class="d-flex gap-2 flex-wrap">
                                <button class="btn btn-outline-secondary" onclick="setTheme('light')">{{ trans('profile.a11y_light') }}</button>
                                <button class="btn btn-outline-secondary" onclick="setTheme('dark')">{{ trans('profile.a11y_dark') }}</button>
                                <button class="btn btn-outline-secondary" onclick="setTheme('system')">{{ trans('profile.a11y_system') }}</button>
                            </div>
                        </div>

                        {# Text Size #}
                        <div class="mb-4">
                            <h6 class="fw-bold text-purple mb-2">{{ trans('profile.a11y_text_size') }}</h6>
                            <div class="d-flex align-items-center gap-3">
                                <button class="btn btn-outline-secondary btn-sm" onclick="adjustFontSize(-1)">A−</button>
                                <span id="font-size-label" class="text-muted small">100%</span>
                                <button class="btn btn-outline-secondary btn-sm" onclick="adjustFontSize(1)">A+</button>
                                <button class="btn btn-outline-secondary btn-sm" onclick="resetFontSize()">Reset</button>
                            </div>
                        </div>

                        {# High Contrast #}
                        <div class="mb-4">
                            <h6 class="fw-bold text-purple mb-2">{{ trans('profile.a11y_high_contrast') }}</h6>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="high-contrast-toggle"
                                    onchange="toggleHighContrast(this.checked)">
                                <label class="form-check-label" for="high-contrast-toggle">{{ trans('profile.a11y_high_contrast_label') }}</label>
                            </div>
                        </div>

                        {# Reduce Motion #}
                        <div class="mb-4">
                            <h6 class="fw-bold text-purple mb-2">{{ trans('profile.a11y_reduce_motion') }}</h6>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="reduce-motion-toggle"
                                    onchange="toggleReduceMotion(this.checked)">
                                <label class="form-check-label" for="reduce-motion-toggle">{{ trans('profile.a11y_reduce_motion_label') }}</label>
                            </div>
                        </div>

                        {# Dyslexia Font #}
                        <div class="mb-4">
                            <h6 class="fw-bold text-purple mb-2">{{ trans('profile.a11y_dyslexia_font') }}</h6>
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" id="dyslexia-toggle"
                                    onchange="toggleDyslexiaFont(this.checked)">
                                <label class="form-check-label" for="dyslexia-toggle">{{ trans('profile.a11y_dyslexia_font_label') }}</label>
                            </div>
                        </div>

                        <button class="btn btn-outline-secondary btn-sm" onclick="resetAllAccessibility()">
                            {{ trans('profile.a11y_reset') }}
                        </button>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

<script>
function togglePassword(fieldId, btn) {
    const input = document.getElementById(fieldId);
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.classList.replace('bi-eye', 'bi-eye-slash');
    } else {
        input.type = 'password';
        icon.classList.replace('bi-eye-slash', 'bi-eye');
    }
}

function copySecret() {
    const el = document.getElementById('totpSetupSecret');
    if (!el) return;
    const text = el.textContent;
    navigator.clipboard.writeText(text).then(() => {
        const btn = el.nextElementSibling;
        const icon = btn.querySelector('i');
        icon.classList.replace('bi-clipboard', 'bi-check-lg');
        setTimeout(() => icon.classList.replace('bi-check-lg', 'bi-clipboard'), 1500);
    });
}

// Accessibility stuff

// Sync toggle states to match current settings
document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('high-contrast-toggle').checked = localStorage.getItem('highContrast') === 'true';
    document.getElementById('reduce-motion-toggle').checked = localStorage.getItem('reduceMotion') === 'true';
    document.getElementById('dyslexia-toggle').checked      = localStorage.getItem('dyslexiaFont') === 'true';
    
    const fontSize = parseInt(localStorage.getItem('fontSize') || '100');
    const label = document.getElementById('font-size-label');
    if (label) label.textContent = fontSize + '%';
});

// ── Theme ─────────────────────────────────────────────────────────────────
function setTheme(theme) {
    localStorage.setItem('theme', theme);
    applyTheme(theme);
}

function applyTheme(theme) {
    if (theme === 'dark') {
        document.documentElement.setAttribute('data-bs-theme', 'dark');
    } else if (theme === 'system') {
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        document.documentElement.setAttribute('data-bs-theme', prefersDark ? 'dark' : 'light');
    } else {
        document.documentElement.setAttribute('data-bs-theme', 'light');
    }
}

// ── Font Size ─────────────────────────────────────────────────────────────
let currentFontSize = parseInt(localStorage.getItem('fontSize') || '100');

function adjustFontSize(delta) {
    currentFontSize = Math.min(150, Math.max(75, currentFontSize + delta * 10));
    localStorage.setItem('fontSize', currentFontSize);
    applyFontSize(currentFontSize);
}

function applyFontSize(size) {
    document.documentElement.style.fontSize = size + '%';
    const label = document.getElementById('font-size-label');
    if (label) label.textContent = size + '%';
    currentFontSize = size;
}

function resetFontSize() {
    applyFontSize(100);
    localStorage.setItem('fontSize', '100');
}

// ── High Contrast ─────────────────────────────────────────────────────────
function toggleHighContrast(enabled) {
    localStorage.setItem('highContrast', enabled);
    applyHighContrast(enabled);
}

function applyHighContrast(enabled) {
    if (enabled) {
        document.documentElement.classList.add('high-contrast');
    } else {
        document.documentElement.classList.remove('high-contrast');
    }
}

// ── Reduce Motion ─────────────────────────────────────────────────────────
function toggleReduceMotion(enabled) {
    localStorage.setItem('reduceMotion', enabled);
    applyReduceMotion(enabled);
}

function applyReduceMotion(enabled) {
    if (enabled) {
        document.body.classList.add('reduce-motion');
    } else {
        document.body.classList.remove('reduce-motion');
    }
}

// ── Dyslexia Font ─────────────────────────────────────────────────────────
function toggleDyslexiaFont(enabled) {
    localStorage.setItem('dyslexiaFont', enabled);
    applyDyslexiaFont(enabled);
}

function applyDyslexiaFont(enabled) {
    if (enabled) {
        document.body.classList.add('dyslexia-font');
    } else {
        document.body.classList.remove('dyslexia-font');
    }
}

// ── Reset All ─────────────────────────────────────────────────────────────
function resetAllAccessibility() {
    localStorage.removeItem('fontSize');
    localStorage.removeItem('highContrast');
    localStorage.removeItem('reduceMotion');
    localStorage.removeItem('dyslexiaFont');
    localStorage.removeItem('theme');

    applyFontSize(100);
    applyHighContrast(false);
    applyReduceMotion(false);
    applyDyslexiaFont(false);
    applyTheme('light');

    document.getElementById('high-contrast-toggle').checked = false;
    document.getElementById('reduce-motion-toggle').checked = false;
    document.getElementById('dyslexia-toggle').checked      = false;
}
</script>

{% endblock %}