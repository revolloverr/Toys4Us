{% extends "layout.html.twig" %}

{% block title %}{{ trans('cart.title') }} - {{ trans('app.title') }}{% endblock %}

{% block content %}

<div class="row mb-4">
    <div class="col">
        <h2 class="h4 text-purple fw-bold">{{ trans('cart.title') }}</h2>
    </div>
</div>

{% if cart is empty %}
    <div class="card shadow-sm border-0">
        <div class="card-body text-center py-5">
            <p class="text-muted mb-3">{{ trans('cart.empty') }}</p>
            <a href="{{ base_path }}/products" class="btn btn-purple">
                {{ trans('cart.continue_shopping') }}
            </a>
        </div>
    </div>
{% else %}
    <div class="card shadow-sm border-0">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-borderless align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>{{ trans('cart.product') }}</th>
                            <th class="text-center">{{ trans('cart.qty') }}</th>
                            <th class="text-end">{{ trans('cart.price') }}</th>
                            <th class="text-end">{{ trans('cart.total') }}</th>
                            <th class="text-end">{{ trans('cart.actions') }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set grandTotal = 0 %}
                        {% for key, item in cart %}
                            <tr>
                                <td>
                                    {% if item.type is defined and item.type == 'customplush' and item.plush_details is defined %}
                                        {# ── Custom plush preview ── #}
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="position-relative" style="width:80px; height:80px; flex-shrink:0;">
                                                <img src="{{ base_path }}/{{ item.plush_details.base_image }}"
                                                     alt="{{ item.name }}" class="w-100 h-100"
                                                     style="object-fit:contain;">
                                                {% if item.plush_details.accessories.facewear is not null %}
                                                    <img src="{{ base_path }}/{{ item.plush_details.accessories.facewear.image_path }}"
                                                         alt="" class="position-absolute top-0 start-0 w-100 h-100"
                                                         style="object-fit:contain;">
                                                {% endif %}
                                                {% if item.plush_details.accessories.bodywear is not null %}
                                                    <img src="{{ base_path }}/{{ item.plush_details.accessories.bodywear.image_path }}"
                                                         alt="" class="position-absolute top-0 start-0 w-100 h-100"
                                                         style="object-fit:contain;">
                                                {% endif %}
                                                {% if item.plush_details.accessories.shoes is not null %}
                                                    <img src="{{ base_path }}/{{ item.plush_details.accessories.shoes.image_path }}"
                                                         alt="" class="position-absolute top-0 start-0 w-100 h-100"
                                                         style="object-fit:contain;">
                                                {% endif %}
                                            </div>
                                            <div>
                                                <span class="fw-bold">{{ item.name }}</span>
                                                <span class="badge bg-purple-soft text-purple ms-2">{{ trans('cart.custom_plush_badge') }}</span>
                                                <div class="text-muted small">
                                                    {{ trans('cart.base_label') }} {{ item.plush_details.base_color|capitalize }} {{ item.plush_details.base_species|capitalize }}
                                                </div>
                                            </div>
                                        </div>
                                    {% else %}
                                        {{ item.name }}
                                    {% endif %}
                                </td>
                                <td class="text-center">
                                    <div class="d-flex align-items-center justify-content-center gap-1">
                                        <form action="{{ base_path }}/cart/update/{{ key }}" method="POST" class="d-inline">
                                            {% set decremented = (item.qty is defined ? item.qty : 1) - 1 %}
                                            <input type="hidden" name="qty" value="{{ decremented > 1 ? decremented : 1 }}">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary px-2 py-0"
                                                    {% if (item.qty is defined ? item.qty : 1) <= 1 %}disabled{% endif %}>
                                                <i class="bi bi-dash"></i>
                                            </button>
                                        </form>
                                        <span class="fw-bold mx-1" style="min-width:1.5rem;">{{ item.qty is defined ? item.qty : 1 }}</span>
                                        <form action="{{ base_path }}/cart/update/{{ key }}" method="POST" class="d-inline">
                                            <input type="hidden" name="qty" value="{{ (item.qty is defined ? item.qty : 1) + 1 }}">
                                            <button type="submit" class="btn btn-sm btn-outline-secondary px-2 py-0">
                                                <i class="bi bi-plus"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                                <td class="text-end">${{ item.price|number_format(2) }}</td>
                                <td class="text-end fw-bold">
                                    ${{ (item.price * (item.qty is defined ? item.qty : 1))|number_format(2) }}
                                </td>
                                <td class="text-end">
                                    {% if item.type is defined and item.type == 'customplush' %}
                                        <a href="{{ base_path }}/build/{{ item.plush_id }}"
                                           class="btn btn-sm btn-outline-purple me-1">
                                             <i class="bi bi-pencil"></i> {{ trans('cart.edit') }}
                                        </a>
                                    {% endif %}
                                    <form action="{{ base_path }}/cart/remove/{{ key }}" method="POST"
                                           class="d-inline" onsubmit="return confirm('{{ trans('cart.remove_confirm') }}')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                            {% set itemTotal = item.price * (item.qty is defined ? item.qty : 1) %}
                            {% set grandTotal = grandTotal + itemTotal %}
                        {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="4" class="text-end fw-bold h5">{{ trans('cart.grand_total') }}:</td>
                            <td class="text-end fw-bold h5 text-purple">${{ grandTotal|number_format(2) }}</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between mt-4">
        <a href="{{ base_path }}/products" class="btn btn-outline-secondary">
            {{ trans('cart.continue_shopping') }}
        </a>
        <form action="{{ base_path }}/cart/checkout" method="POST">
            <button type="submit" class="btn btn-purple btn-lg">
                {{ trans('cart.checkout') }}
            </button>
        </form>
    </div>
{% endif %}

{% endblock %}