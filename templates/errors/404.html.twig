{% extends "layout.html.twig" %}

{% block title %}404 - Page Not Found{% endblock %}

{% block content %}
<div class="text-center py-5">
    <div style="font-size: 80px;">🧸</div>
    <h1 class="display-4 fw-bold text-purple mt-3">404</h1>
    <h2 class="h4 text-muted mb-3">Oops! This page got lost in the toy box.</h2>
    <p class="text-muted mb-4">The page you're looking for doesn't exist or has been moved.</p>
    <a href="{{ base_path }}/" class="btn btn-purple btn-lg px-5">Back to Home</a>
</div>
{% endblock %}