{% extends "layout.html.twig" %}

{% block title %}{{ trans('build.title_page') }}{% endblock %}

{% block content %}

{# --- START PRELOAD SECTION --- #}
{% for base in bases %}
    <link rel="preload" as="image" href="{{ base_path }}/{{ base.image_path }}">
{% endfor %}

{% for category in ['facewear', 'bodywear', 'shoes'] %}
    {% for acc in accessories[category] %}
        {% if acc.image_path %}
            <link rel="preload" as="image" href="{{ base_path }}/{{ acc.image_path }}">
        {% endif %}
    {% endfor %}
{% endfor %}
{# --- END PRELOAD SECTION --- #}

<h2 class="h4 text-purple fw-bold mb-4">
{% if edit_plush_id is defined and edit_plush_id > 0 %}
        <a href="{{ base_path }}/cart" class="btn btn-outline-purple btn-sm me-2"><i class="bi bi-arrow-left"></i></a>
        {{ trans('build.edit_heading', {'%name%': edit_plush.name}) }}
    {% else %}
        {{ trans('build.create_heading') }}
    {% endif %}
</h2>

<div class="row g-4">

    {# ── Left: Plush Preview ───────────────────────────────────────────────── #}
    <div class="col-12 col-md-5 text-center">
        <div class="position-relative d-inline-block" style="width:380px; height:380px;">
            {# Base image #}
            <img id="base-img"
                 src="{{ base_path }}/{{ bases|first.image_path }}"
                 alt="Plush Base"
                 class="position-absolute top-0 start-0 w-100 h-100"
                 style="object-fit:contain;">
            {# Facewear overlay #}
            <img id="overlay-facewear"
                 src=""
                 alt=""
                 class="position-absolute top-0 start-0 w-100 h-100 d-none"
                 style="object-fit:contain;">
            {# Bodywear overlay #}
            <img id="overlay-bodywear"
                 src=""
                 alt=""
                 class="position-absolute top-0 start-0 w-100 h-100 d-none"
                 style="object-fit:contain;">
            {# Shoes overlay #}
            <img id="overlay-shoes"
                 src=""
                 alt=""
                 class="position-absolute top-0 start-0 w-100 h-100 d-none"
                 style="object-fit:contain;">
        </div>

        {# Base selector #}
        <div class="d-flex align-items-center justify-content-center gap-3 mt-3">
            <button class="btn btn-outline-purple btn-sm" onclick="cycleSpecies(-1)">&#8249;</button>
            <span id="species-name" class="fw-bold text-purple" style="min-width:80px; text-align:center;">{{ bases|first.species|capitalize }}</span>
            <button class="btn btn-outline-purple btn-sm" onclick="cycleSpecies(1)">&#8250;</button>
        </div>
        <p class="text-muted small text-center mb-1">{{ trans('build.type_label') }}</p>

        {# Color selector #}
        <div class="d-flex align-items-center justify-content-center gap-3">
            <button class="btn btn-outline-purple btn-sm" onclick="cycleColor(-1)">&#8249;</button>
            <span id="color-name" class="fw-bold text-purple" style="min-width:80px; text-align:center;">{{ bases|first.color|capitalize }}</span>
            <button class="btn btn-outline-purple btn-sm" onclick="cycleColor(1)">&#8250;</button>
        </div>
        <p class="text-muted small text-center mb-1">{{ trans('build.color_label') }}</p>
        <p class="text-muted small text-center">{{ trans('build.base_price_label') }}<span id="base-price">{{ bases|first.base_price }}</span></p>

        <div class="d-flex justify-content-center gap-2 mt-2">
            <button class="btn btn-outline-secondary btn-sm" onclick="resizePreview(-20)">−</button>
            <button class="btn btn-outline-secondary btn-sm" onclick="resizePreview(0)">{{ trans('profile.a11y_reset') }}</button>
            <button class="btn btn-outline-secondary btn-sm" onclick="resizePreview(20)">+</button>
        </div>
    </div>

    {# ── Right: Accessories + Form ─────────────────────────────────────────── #}
    <div class="col-12 col-md-7">

        {# Facewear #}
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-purple mb-2">{{ trans('build.face_wear') }}</h6>
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-outline-secondary btn-sm" onclick="cycleAccessory('facewear', -1)">&#8249;</button>
                    <span id="facewear-name" class="flex-grow-1 text-center">{{ edit_plush.accessories.facewear.name ?? trans('build.none') }}</span>
                    <button class="btn btn-outline-secondary btn-sm" onclick="cycleAccessory('facewear', 1)">&#8250;</button>
                </div>
                <p class="text-muted small text-center mt-1 mb-0">+$<span id="facewear-price">{{ edit_plush.accessories.facewear.price ?? '0.00' }}</span></p>
            </div>
        </div>

        {# Bodywear #}
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-purple mb-2">{{ trans('build.body_wear') }}</h6>
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-outline-secondary btn-sm" onclick="cycleAccessory('bodywear', -1)">&#8249;</button>
                    <span id="bodywear-name" class="flex-grow-1 text-center">{{ edit_plush.accessories.bodywear.name ?? trans('build.none') }}</span>
                    <button class="btn btn-outline-secondary btn-sm" onclick="cycleAccessory('bodywear', 1)">&#8250;</button>
                </div>
                <p class="text-muted small text-center mt-1 mb-0">+$<span id="bodywear-price">{{ edit_plush.accessories.bodywear.price ?? '0.00' }}</span></p>
            </div>
        </div>

        {# Footwear #}
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-purple mb-2">{{ trans('build.footwear') }}</h6>
                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-outline-secondary btn-sm" onclick="cycleAccessory('shoes', -1)">&#8249;</button>
                    <span id="shoes-name" class="flex-grow-1 text-center">{{ edit_plush.accessories.shoes.name ?? trans('build.none') }}</span>
                    <button class="btn btn-outline-secondary btn-sm" onclick="cycleAccessory('shoes', 1)">&#8250;</button>
                </div>
                <p class="text-muted small text-center mt-1 mb-0">+$<span id="shoes-price">{{ edit_plush.accessories.shoes.price ?? '0.00' }}</span></p>
            </div>
        </div>

        {# Name + TTS #}
        <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
                <h6 class="fw-bold text-purple mb-2">{{ trans('build.name_your_plush') }}</h6>
                <input type="text" id="plush-name-input" class="form-control mb-2"
                       placeholder="{{ trans('build.name_placeholder') }}" maxlength="50"
                       value="{{ edit_plush.name ?? '' }}">

                <h6 class="fw-bold text-purple mb-2 mt-3">{{ trans('build.voice_message') }}</h6>
                <div class="input-group mb-2">
                    <input type="text" id="tts-text" class="form-control"
                           placeholder="{{ trans('build.voice_placeholder') }}" maxlength="200">
                    <button class="btn btn-outline-purple" type="button" onclick="previewTTS()">
                        <i class="bi bi-volume-up me-1"></i>{{ trans('build.voice_preview') }}
                    </button>
                </div>
                <p class="text-muted small">{{ trans('build.voice_note') }}</p>
            </div>
        </div>

        {# Total + Actions #}
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="fw-bold">{{ trans('build.total') }}</span>
                    <span class="fw-bold text-purple fs-5">$<span id="total-price">{{ edit_plush.total_price ?? bases|first.base_price }}</span></span>
                </div>
                <form id="build-form" action="{{ base_path }}/build" method="POST">
                    <input type="hidden" name="base_id" id="form-base-id" value="{{ edit_plush.base_id ?? bases|first.id }}">
                    <input type="hidden" name="plush_name" id="form-plush-name" value="{{ edit_plush.name ?? 'My Plush' }}">
                    <input type="hidden" name="accessory_ids[]" id="form-facewear-id" value="{{ edit_plush.accessories.facewear.id ?? '' }}">
                    <input type="hidden" name="accessory_ids[]" id="form-bodywear-id" value="{{ edit_plush.accessories.bodywear.id ?? '' }}">
                    <input type="hidden" name="accessory_ids[]" id="form-shoes-id" value="{{ edit_plush.accessories.shoes.id ?? '' }}">
                    {% if edit_plush_id is defined and edit_plush_id > 0 %}
                        <input type="hidden" name="edit_plush_id" value="{{ edit_plush_id }}">
                    {% endif %}
                    <button type="submit" name="action" value="cart" class="btn btn-purple w-100">
                        <i class="bi bi-check-lg me-1"></i>{{ edit_plush_id is defined and edit_plush_id > 0 ? trans('build.save_changes') : trans('build.add_to_cart') }}
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

{# ── JavaScript ────────────────────────────────────────────────────────────── #}
<script>
const basePath = "{{ base_path }}";

const bases = [
    {% for base in bases %}
    {
        id:      {{ base.id }},
        name:    "{{ base.name }}",
        species: "{{ base.species }}",
        color:   "{{ base.color }}",
        image:   "{{ base_path }}/{{ base.image_path }}",
        price:   {{ base.base_price }}
    }{{ not loop.last ? ',' : '' }}
    {% endfor %}
];

const accessories = {
    facewear: [
        { id: 0, name: 'None', image: '', price: 0 },
        {% for acc in accessories.facewear %}
        { id: {{ acc.id }}, name: "{{ acc.name }}", image: "{{ base_path }}/{{ acc.image_path }}", price: {{ acc.price }} }{{ not loop.last ? ',' : '' }}
        {% endfor %}
    ],
    bodywear: [
        { id: 0, name: 'None', image: '', price: 0 },
        {% for acc in accessories.bodywear %}
        { id: {{ acc.id }}, name: "{{ acc.name }}", image: "{{ base_path }}/{{ acc.image_path }}", price: {{ acc.price }} }{{ not loop.last ? ',' : '' }}
        {% endfor %}
    ],
    shoes: [
        { id: 0, name: 'None', image: '', price: 0 },
        {% for acc in accessories.shoes %}
        { id: {{ acc.id }}, name: "{{ acc.name }}", image: "{{ base_path }}/{{ acc.image_path }}", price: {{ acc.price }} }{{ not loop.last ? ',' : '' }}
        {% endfor %}
    ]
};

const speciesList = {{ species|json_encode|raw }};

{# ── Edit mode: find and set initial indices ── #}
{% if edit_plush_id is defined and edit_plush_id > 0 %}
{% set edit_species = edit_plush.base_species %}
{% set edit_color = edit_plush.base_color %}
{% set edit_facewear_id = edit_plush.accessories.facewear.id ?? 0 %}
{% set edit_bodywear_id = edit_plush.accessories.bodywear.id ?? 0 %}
{% set edit_shoes_id = edit_plush.accessories.shoes.id ?? 0 %}
{% endif %}

let speciesIndex = 0;
let colorIndex   = 0;
const accIndex   = { facewear: 0, bodywear: 0, shoes: 0 };

{# ── Set edit indices from server data ── #}
{% if edit_plush_id is defined and edit_plush_id > 0 %}
// Set species index
speciesIndex = speciesList.indexOf("{{ edit_plush.base_species }}");
if (speciesIndex < 0) speciesIndex = 0;
// Set color index
const initialColors = bases.filter(b => b.species === speciesList[speciesIndex]);
for (let i = 0; i < initialColors.length; i++) {
    if (initialColors[i].color === "{{ edit_plush.base_color }}") {
        colorIndex = i;
        break;
    }
}
// Set accessory indices
for (const [cat, list] of Object.entries(accessories)) {
    {% if edit_facewear_id > 0 %}
    if (cat === 'facewear') {
        for (let i = 0; i < list.length; i++) {
            if (list[i].id === {{ edit_facewear_id }}) { accIndex.facewear = i; break; }
        }
    }
    {% endif %}
    {% if edit_bodywear_id > 0 %}
    if (cat === 'bodywear') {
        for (let i = 0; i < list.length; i++) {
            if (list[i].id === {{ edit_bodywear_id }}) { accIndex.bodywear = i; break; }
        }
    }
    {% endif %}
    {% if edit_shoes_id > 0 %}
    if (cat === 'shoes') {
        for (let i = 0; i < list.length; i++) {
            if (list[i].id === {{ edit_shoes_id }}) { accIndex.shoes = i; break; }
        }
    }
    {% endif %}
}
{% endif %}

function getCurrentBase() {
    const currentSpecies = speciesList[speciesIndex];
    const colorsForSpecies = bases.filter(b => b.species === currentSpecies);
    return colorsForSpecies[colorIndex % colorsForSpecies.length];
}

function cycleSpecies(dir) {
    speciesIndex = (speciesIndex + dir + speciesList.length) % speciesList.length;
    colorIndex   = 0;
    updateBase();
}

function cycleColor(dir) {
    const currentSpecies    = speciesList[speciesIndex];
    const colorsForSpecies  = bases.filter(b => b.species === currentSpecies);
    colorIndex = (colorIndex + dir + colorsForSpecies.length) % colorsForSpecies.length;
    updateBase();
}

function updateTotal() {
    const base  = getCurrentBase().price;
    const fw    = accessories.facewear[accIndex.facewear].price;
    const bw    = accessories.bodywear[accIndex.bodywear].price;
    const sh    = accessories.shoes[accIndex.shoes].price;
    document.getElementById('total-price').textContent = (base + fw + bw + sh).toFixed(2);
}

function updateBase() {
    const base = getCurrentBase();
    document.getElementById('base-img').src             = base.image;
    document.getElementById('species-name').textContent = base.species.charAt(0).toUpperCase() + base.species.slice(1);
    document.getElementById('color-name').textContent   = base.color.charAt(0).toUpperCase() + base.color.slice(1);
    document.getElementById('base-price').textContent   = base.price.toFixed(2);
    document.getElementById('form-base-id').value       = base.id;
    updateTotal();
}

function cycleAccessory(category, dir) {
    const list = accessories[category];
    accIndex[category] = (accIndex[category] + dir + list.length) % list.length;
    const acc  = list[accIndex[category]];

    document.getElementById(`${category}-name`).textContent  = acc.name;
    document.getElementById(`${category}-price`).textContent = acc.price.toFixed(2);
    document.getElementById(`form-${category}-id`).value     = acc.id || '';

    const overlay = document.getElementById(`overlay-${category}`);
    if (acc.image) {
        overlay.src = acc.image;
        overlay.classList.remove('d-none');
    } else {
        overlay.src = '';
        overlay.classList.add('d-none');
    }

    updateTotal();
}

// Sync plush name to hidden form field
document.getElementById('plush-name-input').addEventListener('input', function() {
    document.getElementById('form-plush-name').value = this.value || 'My Plush';
});

// TTS preview using Web Speech API
function previewTTS() {
    const text = document.getElementById('tts-text').value.trim();
    if (!text) return;
    const utterance = new SpeechSynthesisUtterance(text);
    utterance.lang = 'en-US';
    window.speechSynthesis.cancel();
    window.speechSynthesis.speak(utterance);
}

let previewSize = 380;

function resizePreview(delta) {
    if (delta === 0) {
        previewSize = 380;
    } else {
        previewSize = Math.min(500, Math.max(150, previewSize + delta));
    }
    const container = document.querySelector('.position-relative.d-inline-block');
    container.style.width  = previewSize + 'px';
    container.style.height = previewSize + 'px';
}

// Initialise to edit plush if set
{% if edit_plush_id is defined and edit_plush_id > 0 %}
// Show accessories overlays for edit mode
{% for cat in ['facewear', 'bodywear', 'shoes'] %}
{% set acc = edit_plush.accessories[cat] %}
{% if acc is not null %}
(function() {
    const overlay = document.getElementById('overlay-{{ cat }}');
    if (overlay) {
        overlay.src = '{{ base_path }}/{{ acc.image_path }}';
        overlay.classList.remove('d-none');
    }
})();
{% endif %}
{% endfor %}
updateBase();
{% endif %}
</script>

{% endblock %}