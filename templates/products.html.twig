{% extends "layout.html.twig" %}

{% block title %}{{ trans('app.title') }}{% endblock %}

{% block content %}

<div class="row mb-4">
    <div class="col">
        <h2 class="h4 text-purple fw-bold">{{ trans('products.heading') }}</h2>
        <p class="text-muted">{{ trans('products.subheading') }}</p>
    </div>
</div>

<div class="row g-4">
    {% for product in products %}
        <div class="col-12 col-sm-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0">
                <img src="{{ product.image }}" class="card-img-top" alt="{{ product.name }}" style="height:200px;object-fit:cover;">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title fw-bold">{{ product.name }}</h5>
                    <p class="card-text text-muted small flex-grow-1">{{ product.description }}</p>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span class="h5 mb-0 text-purple fw-bold">${{ product.price|number_format(2) }}</span>
                        <a href="{{ base_path }}/products/{{ product.id }}" class="btn btn-purple btn-sm">
                            {{ trans('products.view') }}
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endfor %}
</div>

{% endblock %}