{% extends "layout.html.twig" %}

{% block title %}{{ trans('products.heading') }}{% endblock %}

{% block content %}

<div class="row mb-4">
    <div class="col">
        <h2 class="h4 text-purple fw-bold">{{ trans('products.heading') }}</h2>
        <p class="text-muted">{{ trans('products.subheading') }}</p>
    </div>
</div>

<div class="row g-4">

    {# ── Search ───────────────────────────────────────────────────── #}
    <div class="row mb-3">
        <div class="col">
            <div class="d-flex gap-2">
                <div class="position-relative flex-grow-1">
                    <input type="text" id="live-search-input" class="form-control"
                        placeholder="{{ trans('products.search_placeholder') }}"
                        value="{{ filters.search ?? '' }}"
                        autocomplete="off">
                    <div id="live-search-results" class="position-absolute w-100 shadow-sm rounded"
                         style="z-index:1000; display:none; max-height:400px; overflow-y:auto; background:#fff; border:1px solid #ddd;"></div>
                </div>
                <button type="submit" class="btn btn-purple" onclick="document.getElementById('live-search-input').form.submit()">
                    <i class="bi bi-search me-1"></i>{{ trans('products.search_btn') }}
                </button>
            </div>
            <form method="GET" action="{{ base_path }}/products" id="search-form" class="d-none">
                <input type="hidden" name="search" id="search-hidden">
            </form>
        </div>
    </div>

    {# ── Sidebar Filters ───────────────────────────────────────────────────── #}
    <div class="col-12 col-md-3">
        <form method="GET" action="{{ base_path }}/products" id="filter-form">

            {# Category #}
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h6 class="fw-bold text-purple mb-3">{{ trans('products.filter_category') }}</h6>
                    <div class="d-flex flex-column gap-2">
                        <a href="{{ base_path }}/products"
                           class="btn btn-sm {{ not app.request.query.get('category') ? 'btn-purple' : 'btn-outline-purple' }}">
                            {{ trans('products.filter_all') }}
                        </a>
                        {% for category in categories %}
                        <a href="{{ base_path }}/products?category={{ category.slug }}{% if filters.min_price is defined and filters.min_price %}&min_price={{ filters.min_price }}{% endif %}{% if filters.max_price is defined and filters.max_price %}&max_price={{ filters.max_price }}{% endif %}{% if filters.min_rating is defined and filters.min_rating %}&min_rating={{ filters.min_rating }}{% endif %}"
                           class="btn btn-sm {{ filters.category is defined and filters.category == category.slug ? 'btn-purple' : 'btn-outline-purple' }}">
                            {{ category.name }}
                        </a>
                        {% endfor %}
                    </div>
                </div>
            </div>

            {# Price Range #}
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h6 class="fw-bold text-purple mb-3">{{ trans('products.filter_price_range') }}</h6>
                    <div class="mb-2">
                        <label class="form-label small text-muted">{{ trans('products.filter_min_price') }}</label>
                        <input type="number" name="min_price" class="form-control form-control-sm"
                               placeholder="0" min="0" step="0.01"
                               value="{{ filters.min_price ?? '' }}">
                    </div>
                    <div class="mb-3">
                        <label class="form-label small text-muted">{{ trans('products.filter_max_price') }}</label>
                        <input type="number" name="max_price" class="form-control form-control-sm"
                               placeholder="Any" min="0" step="0.01"
                               value="{{ filters.max_price ?? '' }}">
                    </div>
                    {% if filters.category is defined and filters.category %}
                        <input type="hidden" name="category" value="{{ filters.category }}">
                    {% endif %}
                    {% if filters.min_rating is defined and filters.min_rating %}
                        <input type="hidden" name="min_rating" value="{{ filters.min_rating }}">
                    {% endif %}
                </div>
            </div>

            {# Rating #}
            <div class="card shadow-sm border-0 mb-3">
                <div class="card-body">
                    <h6 class="fw-bold text-purple mb-3">{{ trans('products.filter_min_rating') }}</h6>
                    <div class="d-flex flex-column gap-2">
                        {% for stars in [1, 2, 3, 4, 5] %}
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="min_rating"
                                   id="rating{{ stars }}" value="{{ stars }}"
                                   {{ filters.min_rating is defined and filters.min_rating == stars ? 'checked' : '' }}>
                            <label class="form-check-label" for="rating{{ stars }}">
                                {% for i in 1..stars %}⭐{% endfor %} {{ trans('products.filter_rating_up') }}
                            </label>
                        </div>
                        {% endfor %}
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="min_rating"
                                   id="ratingAny" value=""
                                   {{ filters.min_rating is not defined or not filters.min_rating ? 'checked' : '' }}>
                            <label class="form-check-label" for="ratingAny">{{ trans('products.filter_rating_any') }}</label>
                        </div>
                    </div>
                </div>
            </div>

            <button type="submit" class="btn btn-purple w-100">{{ trans('products.filter_apply') }}</button>
            <a href="{{ base_path }}/products" class="btn btn-outline-secondary w-100 mt-2">{{ trans('products.filter_clear') }}</a>

        </form>
    </div>

    {# ── Product Grid ──────────────────────────────────────────────────────── #}
    <div class="col-12 col-md-9">

        {# Results count #}
        <p class="text-muted small mb-3">
            {% set count = products|length %}
            {{ count == 1 ? trans('products.showing_results', {'%count%': 1})|split('|')[0] : trans('products.showing_results', {'%count%': count})|split('|')[1] }}
            {% if filters.category is defined and filters.category %}
                {{ trans('products.results_in_category', {'%category%': filters.category})|raw }}
            {% endif %}
        </p>

        <div id="product-grid">
        {% if products is empty %}
            <div class="text-center py-5">
                <p class="text-muted fs-5">{{ trans('products.no_results') }}</p>
                <a href="{{ base_path }}/products" class="btn btn-purple mt-2">{{ trans('products.filter_clear') }}</a>
            </div>
        {% else %}
            <div class="row g-4">
                {% for product in products %}
                <div class="col-12 col-sm-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="{{ product.image }}" class="card-img-top"
                             alt="{{ product.name }}" style="height:200px;object-fit:contain;">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold">{{ product.name }}</h5>
                            <p class="card-text text-muted small flex-grow-1">{{ product.description }}</p>
                            {% if product.rating %}
                                <p class="mb-1 small">
                                    {% for i in 1..5 %}
                                        {{ i <= product.rating ? '⭐' : '☆' }}
                                    {% endfor %}
                                    <span class="text-muted">({{ product.rating|number_format(1) }})</span>
                                </p>
                            {% endif %}
                            <div class="d-flex justify-content-between align-items-center mt-2">
                                <span class="h5 mb-0 text-purple fw-bold">${{ product.price|number_format(2) }}</span>
                                <a href="{{ base_path }}/products/{{ product.id }}" class="btn btn-purple btn-sm">
                                    {{ trans('products.view') }}
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
        </div>
    </div>

</div>

<script>
const basePath = "{{ base_path }}";
const searchInput = document.getElementById('live-search-input');
const resultsBox = document.getElementById('live-search-results');
const searchNoResults = "{{ trans('products.no_results')|e('js') }}";
const searchViewText = "{{ trans('products.view')|e('js') }}";
const searchBtnText = "{{ trans('products.search_btn')|e('js') }}";
const searchHeading = "{{ trans('products.heading')|e('js') }}";
let debounceTimer = null;

searchInput.addEventListener('input', function() {
    clearTimeout(debounceTimer);
    const q = this.value.trim();
    if (q.length < 2) {
        resultsBox.style.display = 'none';
        return;
    }
    debounceTimer = setTimeout(() => performLiveSearch(q), 300);
});

function performLiveSearch(q) {
    fetch(basePath + '/products/search-json?q=' + encodeURIComponent(q))
        .then(res => res.json())
        .then(data => {
            if (!data || data.length === 0) {
                resultsBox.innerHTML = '<div class="p-3 text-muted small text-center">' + searchNoResults + '</div>';
                resultsBox.style.display = 'block';
                return;
            }
            let html = '';
            data.slice(0, 8).forEach(p => {
                html += '<a href="' + basePath + '/products/' + p.id + '" class="d-flex align-items-center gap-2 p-2 text-decoration-none border-bottom" style="cursor:pointer;">';
                if (p.image) {
                    html += '<img src="' + p.image + '" alt="" style="width:40px;height:40px;object-fit:cover;border-radius:4px;">';
                }
                html += '<div class="flex-grow-1"><div class="fw-bold small text-dark">' + escapeHtml(p.name) + '</div>';
                html += '<div class="text-muted" style="font-size:0.75rem;">$' + p.price.toFixed(2) + '</div></div>';
                html += '<span class="btn btn-purple btn-sm">' + searchViewText + '</span></a>';
            });
            if (data.length > 8) {
                html += '<div class="p-2 text-center"><a href="' + basePath + '/products?search=' + encodeURIComponent(q) + '" class="small text-purple">' + searchBtnText + ' ' + data.length + ' ' + searchHeading + '</a></div>';
            }
            resultsBox.innerHTML = html;
            resultsBox.style.display = 'block';
        })
        .catch(() => {
            resultsBox.style.display = 'none';
        });
}

function escapeHtml(str) {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
}

// Close dropdown on click outside
document.addEventListener('click', function(e) {
    if (!e.target.closest('#live-search-input') && !e.target.closest('#live-search-results')) {
        resultsBox.style.display = 'none';
    }
});

// Submit on Enter
searchInput.addEventListener('keydown', function(e) {
    if (e.key === 'Enter') {
        e.preventDefault();
        document.getElementById('search-hidden').value = this.value;
        document.getElementById('search-form').submit();
    }
});
</script>

{% endblock %}