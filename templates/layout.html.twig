<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ trans('app.title') }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="{{ base_path }}/assets/style.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    
</head>
<body class="bg-light d-flex flex-column min-vh-100">
    <!-- ─── STICKY NAVBAR ────────────────────────────────────────────────── -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-purple shadow-sm sticky-top py-3">
        <div class="container-fluid px-5">
            <a class="navbar-brand fw-bold fs-4 d-flex align-items-center gap-2" href="{{ base_path }}/">
                <img src="{{ base_path }}/assets/bases/bear_purple.png" alt="Toys4Us" style="height:32px; width:32px; object-fit:contain;">
                {{ trans('app.title') }}
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto fs-5 gap-2">
                    <li class="nav-item">
                        <a class="nav-link px-3" href="{{ base_path }}/">{{ trans('nav.home') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3" href="{{ base_path }}/products">{{ trans('nav.products') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3" href="{{ base_path }}/build">{{ trans('nav.build_a_toy') }}</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link px-3" href="{{ base_path }}/about">{{ trans('nav.about_us') }}</a>
                    </li>
                </ul>
                <ul class="navbar-nav align-items-center gap-3">
                    <li class="nav-item lang-switcher">
                        <a href="{{ base_path }}/lang/en"
                           class="nav-link d-inline px-2 py-1 rounded {{ (app_lang ?? 'en') == 'en' ? 'fw-bold text-white' : 'text-white-50' }}">
                            {{ trans('app.lang.en') }}
                        </a>
                        <span class="text-white-50">|</span>
                        <a href="{{ base_path }}/lang/fr"
                           class="nav-link d-inline px-2 py-1 rounded {{ (app_lang ?? 'en') == 'fr' ? 'fw-bold text-white' : 'text-white-50' }}">
                            {{ trans('app.lang.fr') }}
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="{{ base_path }}/cart" class="btn btn-outline-light position-relative">
                            <i class="bi bi-cart me-1"></i>{{ trans('app.cart') }}
                            {% set cartCount = 0 %}
                            {% if app_cart is defined and app_cart is not empty %}
                                {% set cartCount = app_cart|length %}
                            {% endif %}
                            {% if cartCount > 0 %}
                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-light text-purple">
                                    {{ cartCount }}
                                </span>
                            {% endif %}
                        </a>
                    </li>
                       


                    {% if session.user is defined %}
                        <li class="nav-item">
                            <a href="{{ base_path }}/profile" class="btn btn-outline-light me-1">
                                {{ session.user.name }}
                            </a>
                        </li>

                        {% if session.user is defined and session.user.role == 'admin' %}
                            <li class="nav-item">
                                <a href="{{ base_path }}/admin" class="btn btn-warning btn-sm">
                                    <i class="bi bi-gear me-1"></i>Admin
                                </a>
                            </li>
                        {% endif %}  

                        <li class="nav-item">
                            <form action="{{ base_path }}/logout" method="POST" class="m-0">
                                <button type="submit" class="btn btn-outline-light">{{trans('app.logout')}}</button>
                            </form>
                        </li>
                    {% else %}
                        <li class="nav-item">
                            <a href="{{ base_path }}/login" class="btn btn-outline-light">{{trans('app.signin')}}</a>
                        </li>
                    {% endif %}
                </ul>
            </div>
        </div>
    </nav>

    <!-- ─── MAIN CONTENT ────────────────────────────────────────────────── -->
    <main class="flex-grow-1">
        <div class="container py-4">
            {% block content %}{% endblock %}
        </div>
    </main>

    <!-- ─── FOOTER ───────────────────────────────────────────────────────── -->
    <footer class="bg-purple text-white pt-5 pb-4 mt-auto">
        <div class="container">
            <div class="row g-4">
                <!-- Mailing List -->
                <div class="col-12 col-md-4">
                    <h6 class="fw-bold mb-3">{{ trans('footer.mailing_list_title') }}</h6>
                    <form class="d-flex" onsubmit="alert('{{ trans('footer.mailing_list_title') }} — demo only'); return false;">
                        <input type="email" class="form-control form-control-sm me-2" placeholder="{{ trans('footer.mailing_list_ph') }}" required>
                        <button type="submit" class="btn btn-light btn-sm text-purple fw-bold">{{ trans('footer.mailing_list_btn') }}</button>
                    </form>
                </div>
                <!-- Contact Info -->
                <div class="col-12 col-md-4">
                    <h6 class="fw-bold mb-3">{{ trans('app.title') }}</h6>
                    <p class="mb-1 small"><i class="bi bi-envelope me-1"></i><a href="mailto:toys4us@example.com" class="text-white text-decoration-none">{{ trans('footer.contact_email') }}</a></p>
                    <p class="mb-0 small"><i class="bi bi-telephone me-1"></i>{{ trans('footer.contact_phone') }}</p>
                </div>
                <!-- Social Media Icons -->
                <div class="col-12 col-md-4">
                    <h6 class="fw-bold mb-3">{{ trans('footer.follow_us') }}</h6>
                    <div class="d-flex gap-3 fs-4">
                        <a href="#" class="text-white text-decoration-none" title="Facebook"><i class="bi bi-facebook"></i></a>
                        <a href="#" class="text-white text-decoration-none" title="Twitter / X"><i class="bi bi-twitter-x"></i></a>
                        <a href="#" class="text-white text-decoration-none" title="Instagram"><i class="bi bi-instagram"></i></a>
                        <a href="#" class="text-white text-decoration-none" title="TikTok"><i class="bi bi-tiktok"></i></a>
                        <a href="#" class="text-white text-decoration-none" title="YouTube"><i class="bi bi-youtube"></i></a>
                    </div>
                </div>
            </div>
            <hr class="border-white-50 my-4">
            <p class="text-center small mb-0 text-white-50">{{ trans('footer.rights') }}</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>