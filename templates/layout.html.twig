<!DOCTYPE html>
<html lang="{{ app_lang ?? 'en' }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ trans('app.title') }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ base_path }}/assets/style.css">
</head>
<body class="bg-light">
    <div class="container py-4">
        <header class="mb-4">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h1 class="display-6 fw-bold text-purple">{{ trans('app.title') }}</h1>
                    <p class="text-muted">{{ trans('app.subtitle') }}</p>
                </div>
                <nav class="d-flex align-items-center gap-3 mt-2">
                    <div class="lang-switcher">
                        <a href="{{ base_path }}/lang/en"
                           class="text-decoration-none px-2 py-1 rounded {{ (app_lang ?? 'en') == 'en' ? 'fw-bold text-purple' : 'text-muted' }}">
                            {{ trans('app.lang.en') }}
                        </a>
                        <span class="text-muted">|</span>
                        <a href="{{ base_path }}/lang/fr"
                           class="text-decoration-none px-2 py-1 rounded {{ (app_lang ?? 'en') == 'fr' ? 'fw-bold text-purple' : 'text-muted' }}">
                            {{ trans('app.lang.fr') }}
                        </a>
                    </div>
                    <a href="{{ base_path }}/cart" class="btn btn-outline-purple btn-sm position-relative">
                        🛒 {{ trans('app.cart') }}
                        {% set cartCount = 0 %}
                        {% if app_cart is defined and app_cart is not empty %}
                            {% set cartCount = app_cart|length %}
                        {% endif %}
                        {% if cartCount > 0 %}
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-purple">
                                {{ cartCount }}
                            </span>
                        {% endif %}
                    </a>
                    {% if app_authenticated ?? false %}
                        <form action="{{ base_path }}/auth/logout" method="POST" class="m-0">
                            <button type="submit" class="btn btn-outline-secondary btn-sm">
                                {{ trans('app.logout') }}
                            </button>
                        </form>
                    {% endif %}
                </nav>
            </div>
        </header>

        <main>
            {% block content %}{% endblock %}
        </main>

        <footer class="text-center text-muted small mt-5 pt-4 border-top">
            {{ trans('app.footer') }}
        </footer>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>